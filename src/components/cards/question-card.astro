---
import { cn } from "../../lib/utils";
import type { QuestionCard } from "../../lib/data/question-cards";

interface Props {
  card: QuestionCard;
  showAnswer?: boolean;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { card, showAnswer = false, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-32 h-44 text-xs",
  md: "w-48 h-64 text-sm",
  lg: "w-64 h-80 text-base",
};

const difficultyColors = {
  easy: "border-green-500 bg-green-50",
  medium: "border-yellow-500 bg-yellow-50",
  hard: "border-red-500 bg-red-50",
};

const difficultyBadge = {
  easy: "bg-green-500 text-white",
  medium: "bg-yellow-500 text-white",
  hard: "bg-red-500 text-white",
};
---

<div
  class={cn(
    "question-card relative rounded-lg border-4 shadow-xl overflow-hidden",
    difficultyColors[card.difficulty],
    sizeClasses[size],
    className,
  )}
>
  <!-- Header with Difficulty Badge -->
  <div class="p-3 bg-white border-b-2 border-gray-200 flex items-center justify-between">
    <span class={cn("px-3 py-1 rounded-full text-xs font-bold uppercase", difficultyBadge[card.difficulty])}>
      {card.difficulty}
    </span>
    <span class="text-gray-600 font-bold">{card.points} pts</span>
  </div>

  <!-- Question -->
  <div class="p-3 space-y-3">
    <div class="flex items-start gap-2">
      <div class="w-6 h-6 bg-gray-700 text-white rounded-full flex items-center justify-center shrink-0 text-xs font-bold">
        ?
      </div>
      <p class="text-gray-800 font-medium leading-tight flex-1">{card.question}</p>
    </div>

    <!-- Options -->
    <div class="space-y-2">
      {
        card.options.map((option, index) => (
          <div
            class={cn(
              "px-3 py-2 rounded-md border-2 text-xs",
              showAnswer && index === card.correctAnswer
                ? "border-green-500 bg-green-100 font-bold"
                : "border-gray-300 bg-white",
            )}
          >
            <span class="font-semibold mr-2">{String.fromCharCode(65 + index)}.</span>
            {option}
          </div>
        ))
      }
    </div>
  </div>

  <!-- Did You Know Section (if exists) -->
  {
    card.didYouKnow && (
      <div class="absolute bottom-0 left-0 right-0 bg-blue-500 p-2 text-white">
        <div class="flex items-start gap-1">
          <div class="text-yellow-300 text-lg shrink-0">💡</div>
          <div>
            <p class="font-bold text-xs">{card.didYouKnow.title}</p>
            <p class="text-xs opacity-90 mt-0.5 leading-tight line-clamp-2">
              {card.didYouKnow.description}
            </p>
          </div>
        </div>
      </div>
    )
  }
</div>
