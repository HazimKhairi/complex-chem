  }
  .l2-nav-btn--secondary {
    background: #fff;
    color: #475569;
    border: 2px solid #cbd5e1;
    box-shadow: 0 3px 0 #cbd5e1;
  }
  .l2-nav-btn--secondary:hover { background: #f8fafc; transform: translateY(1px); box-shadow: 0 2px 0 #cbd5e1; }

  /* Top-left utility-icon cluster — Kahoot-mock vibe. The 4 buttons
     are decorative wraps around the existing AudioManager / settings
     hooks, sized so they live alongside the brand cluster on the HUD. */
  .l2-util-icons {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
  }
  .l2-util-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: rgba(255,255,255,0.16);
    color: #fff;
    display: inline-flex;
    align-items: center;
