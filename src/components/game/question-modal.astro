---
---

<div
  id="question-modal"
  class="fixed inset-0 z-50 hidden animate-fadeIn"
  data-state="idle"
>
  <!-- Background: mint base + faded ligand silhouettes -->
  <div class="qm-backdrop absolute inset-0"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col w-full h-full p-4 sm:p-6 lg:p-8 overflow-y-auto">

    <!-- Top bar -->
    <header class="flex items-center justify-between gap-3 sm:gap-4">
      <!-- Top-left: Complex-Chem logo -->
      <div class="qm-logo flex items-center gap-2">
        <img
          src="/favicon.png"
          alt="Complex-Chem"
          class="w-10 h-10 sm:w-12 sm:h-12 rounded-2xl shadow-lg bg-white p-1.5"
          onerror="this.style.display='none'"
        />
        <span class="hidden sm:inline-block text-white font-black tracking-tight text-lg drop-shadow-md" style="font-family:'Fredoka',system-ui,sans-serif;">
          Complex&nbsp;Chem
        </span>
      </div>

      <!-- Top-center: timer -->
      <div id="qm-timer" class="qm-timer flex items-center gap-2 px-4 py-2 rounded-2xl bg-white shadow-xl border-4 border-emerald-300">
        <svg class="w-6 h-6 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="13" r="8"/>
          <path d="M12 9v4l2 2"/>
          <path d="M5 3 2 6"/>
          <path d="m22 6-3-3"/>
        </svg>
        <span id="qm-timer-text" class="font-black text-2xl text-emerald-700 tabular-nums" style="font-family:'Fredoka',system-ui,sans-serif;min-width:2ch;">--</span>
      </div>

      <!-- Top-right: difficulty + player -->
      <div class="flex items-center gap-2 sm:gap-3">
        <div id="qm-difficulty" class="qm-pill px-3 sm:px-4 py-2 rounded-2xl text-white font-bold text-xs sm:text-sm shadow-lg flex items-center gap-2">
          <span id="qm-difficulty-label">--</span>
          <span class="w-px h-4 bg-white/40"></span>
          <span id="qm-difficulty-points">--</span>
        </div>
        <div id="qm-player" class="qm-pill hidden sm:flex px-3 sm:px-4 py-2 rounded-2xl bg-white text-slate-700 font-bold text-xs sm:text-sm shadow-lg items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-emerald-500" id="qm-player-dot"></span>
          <span id="qm-player-label">Player 1</span>
        </div>
      </div>
    </header>

    <!-- Center stage -->
    <main class="flex-1 flex flex-col items-center justify-center gap-5 sm:gap-7 mt-6 sm:mt-8 mb-6 sm:mb-8">

      <!-- Question banner -->
      <div id="question-card-container" class="w-full max-w-5xl">
        <!-- Render target — populated by showQuestion() -->
      </div>

      <!-- 4 option grid (2x2) -->
      <div id="question-options" class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 w-full max-w-5xl">
        <!-- Render target -->
      </div>

      <!-- Feedback strip (correct/wrong card) -->
      <div id="question-feedback" class="hidden w-full max-w-5xl">
        <!-- Render target -->
      </div>
    </main>

    <!-- Bottom bar -->
    <footer class="flex items-center justify-between gap-3 sm:gap-4 max-w-5xl w-full mx-auto">
      <!-- Score -->
      <div class="qm-score flex flex-col items-start">
        <span class="text-white/90 text-xs font-semibold tracking-wide drop-shadow">SCORE</span>
        <span id="qm-score-value" class="font-black text-3xl sm:text-5xl text-amber-300 drop-shadow-lg tabular-nums" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>

      <!-- Action row: Submit + Skip -->
      <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 flex-1 max-w-md">
        <button
          id="submit-answer-btn"
          class="flex-1 group relative bg-blue-500 hover:bg-blue-600 text-white font-black py-3 sm:py-4 px-5 rounded-2xl transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed text-sm sm:text-base shadow-lg hover:shadow-xl transform hover:scale-[1.02] active:scale-[0.98]"
          style="font-family:'Fredoka',system-ui,sans-serif;"
        >
          <span class="flex items-center justify-center gap-2">
            <span>Submit</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </span>
        </button>
        <button
          id="skip-question-btn"
          type="button"
          class="px-5 py-3 sm:py-4 rounded-2xl bg-white/95 hover:bg-white border-2 border-white text-slate-700 font-bold text-sm sm:text-base shadow-lg hover:shadow-xl transition-all"
          title="Skip — no points awarded"
          style="font-family:'Fredoka',system-ui,sans-serif;"
        >
          Skip
        </button>
      </div>
    </footer>
  </div>
</div>

<style is:global>
  /* ============================================================
     Modal background — mint gradient + scattered ligand silhouettes
     IMPORTANT: is:global so JS-injected innerHTML (qm-option,
     qm-question-banner) picks up the same selectors. Scoped style
     blocks rewrite class names with a build-time hash that dynamic
     HTML never gets.
     ============================================================ */
  #question-modal .qm-backdrop {
    background:
      radial-gradient(circle at 20% 20%, #a7f3d0 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, #5eead4 0%, transparent 50%),
      linear-gradient(135deg, #6ee7b7 0%, #34d399 50%, #10b981 100%);
    transition: background 0.4s ease;
  }
  /* Difficulty-tinted backdrops — the whole modal background follows
     the board tile colour so it matches the question's difficulty.
     Hazim spec: "colour background soalan based on kesukaran dia". */
  #question-modal .qm-backdrop[data-diff="hard"] {
    background:
      radial-gradient(circle at 20% 20%, #fecaca 0%, transparent 55%),
      radial-gradient(circle at 80% 80%, #fca5a5 0%, transparent 55%),
      linear-gradient(135deg, #f87171 0%, #ef4444 50%, #b91c1c 100%);
  }
  #question-modal .qm-backdrop[data-diff="medium"] {
    background:
      radial-gradient(circle at 20% 20%, #fde68a 0%, transparent 55%),
      radial-gradient(circle at 80% 80%, #fcd34d 0%, transparent 55%),
      linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #b45309 100%);
  }
  #question-modal .qm-backdrop[data-diff="easy"] {
    background:
      radial-gradient(circle at 20% 20%, #bbf7d0 0%, transparent 55%),
      radial-gradient(circle at 80% 80%, #86efac 0%, transparent 55%),
      linear-gradient(135deg, #4ade80 0%, #22c55e 50%, #15803d 100%);
  }

  #question-modal .qm-backdrop::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600' viewBox='0 0 600 600'><g fill='%23ffffff' fill-opacity='0.10' font-family='Fredoka, system-ui, sans-serif' font-weight='700'><text x='40' y='80' font-size='34' transform='rotate(-12 40 80)'>NH%E2%82%83</text><text x='180' y='150' font-size='28' transform='rotate(8 180 150)'>H%E2%82%82O</text><text x='350' y='90' font-size='40' transform='rotate(-5 350 90)'>Cl%E2%81%BB</text><text x='480' y='180' font-size='30' transform='rotate(15 480 180)'>en</text><text x='60' y='280' font-size='32' transform='rotate(20 60 280)'>CN%E2%81%BB</text><text x='220' y='320' font-size='38' transform='rotate(-10 220 320)'>ox</text><text x='420' y='300' font-size='30' transform='rotate(6 420 300)'>py</text><text x='550' y='380' font-size='34' transform='rotate(-18 550 380)'>NH%E2%82%83</text><text x='100' y='450' font-size='30' transform='rotate(10 100 450)'>PPh%E2%82%83</text><text x='280' y='480' font-size='42' transform='rotate(-8 280 480)'>H%E2%82%82O</text><text x='460' y='520' font-size='32' transform='rotate(14 460 520)'>en</text><text x='30' y='560' font-size='28' transform='rotate(-22 30 560)'>acac</text><text x='340' y='220' font-size='26' transform='rotate(25 340 220)'>bipy</text></g></svg>");
    background-repeat: repeat;
    background-size: 600px 600px;
    opacity: 0.85;
    pointer-events: none;
  }

  /* ============================================================
     Difficulty pill colours — JS sets data-diff to swap the bg
     ============================================================ */
  #qm-difficulty[data-diff="hard"]   { background: linear-gradient(135deg,#ef4444,#dc2626); }
  #qm-difficulty[data-diff="medium"] { background: linear-gradient(135deg,#f59e0b,#d97706); }
  #qm-difficulty[data-diff="easy"]   { background: linear-gradient(135deg,#22c55e,#16a34a); }
  #qm-difficulty:not([data-diff])    { background: linear-gradient(135deg,#6366f1,#4f46e5); }

  /* ============================================================
     Timer — pulse red when ≤ 5 seconds remaining
     ============================================================ */
  #qm-timer.qm-timer-low {
    border-color: #ef4444;
    animation: qm-timer-pulse 0.6s ease-in-out infinite alternate;
  }
  #qm-timer.qm-timer-low #qm-timer-text { color: #ef4444; }
  #qm-timer.qm-timer-low svg { color: #ef4444; }
  @keyframes qm-timer-pulse {
    from { transform: scale(1); }
    to   { transform: scale(1.08); }
  }

  /* ============================================================
     Question banner — big rounded blue card, white text, Fredoka
     ============================================================ */
  .qm-question-banner {
    /* default fallback (no difficulty set) — blue */
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 50%, #1e40af 100%);
    color: #fff;
    border-radius: 28px;
    padding: 28px 32px;
    box-shadow: 0 24px 48px -12px rgba(0,0,0,0.35), inset 0 -6px 0 rgba(0,0,0,0.18);
    position: relative;
    overflow: hidden;
  }
  /* Difficulty-driven banner colour: hard=red, medium=yellow, easy=green */
  .qm-question-banner[data-diff="hard"] {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 50%, #991b1b 100%);
  }
  .qm-question-banner[data-diff="medium"] {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 50%, #b45309 100%);
  }
  .qm-question-banner[data-diff="easy"] {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 50%, #15803d 100%);
  }
  .qm-question-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 100% 0%, rgba(255,255,255,0.18) 0%, transparent 50%);
    pointer-events: none;
  }
  .qm-question-text {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.25rem, 2.2vw, 2rem);
    line-height: 1.25;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0,0,0,0.25);
    margin: 0;
  }
  /* Banner with a Note pill — symmetric horizontal padding so the
     centred question text never tucks behind the absolute-positioned
     pill on the right. */
  .qm-question-banner:has(.qm-note-btn) .qm-question-text {
    padding-left: 96px;
    padding-right: 96px;
  }

  /* Note (hint) button — amber pill, top-right corner of the banner.
     `top: 50%; transform: translateY(-50%)` keeps it vertically centred
     against the banner whatever the question wraps to. */
  .qm-note-btn {
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #fde68a;
    color: #78350f;
    border: 2px solid #f59e0b;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.8rem;
    box-shadow: 0 4px 8px rgba(0,0,0,0.18);
    cursor: pointer;
    transition: transform 0.2s, background 0.2s;
    z-index: 2;
  }
  .qm-note-btn:hover  { transform: translateY(-50%) scale(1.05); background: #fcd34d; }
  .qm-note-btn:active { transform: translateY(-50%) scale(0.95); }

  /* Mobile: stack the Note pill above the banner so it never crowds
     the question text on narrow screens. */
  @media (max-width: 640px) {
    .qm-question-banner:has(.qm-note-btn) .qm-question-text {
      padding-left: 0;
      padding-right: 0;
    }
    .qm-note-btn {
      position: static;
      transform: none;
      margin: 0 0 12px;
      align-self: flex-end;
    }
    .qm-note-btn:hover  { transform: scale(1.05); }
    .qm-note-btn:active { transform: scale(0.95); }
    .qm-question-banner { display: flex; flex-direction: column; align-items: stretch; }
  }

  /* ============================================================
     Option buttons — Blooket style. Big, rounded, 4-corner shadow.
     States: idle, selected, correct, wrong, faded.
     ============================================================ */
  .qm-option {
    --opt-bg: #3b82f6;
    --opt-bg-dark: #2563eb;
    background: var(--opt-bg);
    color: #fff;
    border-radius: 22px;
    padding: 22px 24px;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    text-align: left;
    box-shadow: 0 8px 0 var(--opt-bg-dark), 0 12px 24px rgba(0,0,0,0.18);
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    cursor: pointer;
    border: none;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    line-height: 1.3;
  }
  .qm-option:hover {
    transform: translateY(2px);
    box-shadow: 0 6px 0 var(--opt-bg-dark), 0 10px 20px rgba(0,0,0,0.2);
  }
  .qm-option:active {
    transform: translateY(6px);
    box-shadow: 0 2px 0 var(--opt-bg-dark), 0 4px 8px rgba(0,0,0,0.18);
  }

  .qm-option .qm-letter {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    background: rgba(255,255,255,0.25);
    color: #fff;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.1rem;
    box-shadow: inset 0 -3px 0 rgba(0,0,0,0.18);
  }
  .qm-option .qm-text { flex: 1; }

  .qm-option[data-state="selected"] {
    --opt-bg: #f59e0b;
    --opt-bg-dark: #b45309;
    transform: translateY(2px) scale(1.01);
  }
  .qm-option[data-state="correct"] {
    --opt-bg: #22c55e;
    --opt-bg-dark: #15803d;
    animation: qm-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .qm-option[data-state="wrong"] {
    --opt-bg: #ef4444;
    --opt-bg-dark: #991b1b;
    animation: qm-shake 0.5s;
  }
  .qm-option[data-state="faded"] {
    opacity: 0.45;
    pointer-events: none;
  }

  @keyframes qm-pop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.06); }
    100% { transform: scale(1); }
  }
  @keyframes qm-shake {
    0%, 100% { transform: translateX(0); }
    25%      { transform: translateX(-8px); }
    75%      { transform: translateX(8px); }
  }

  /* ============================================================
     Fade-in for the whole modal
     ============================================================ */
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .animate-fadeIn { animation: fadeIn 0.25s ease-out; }
</style>

<script>
  // Submit / skip wiring — same event names so handlers in
  // game-mechanics-cards.js, auto-play.js, orchestrator stay intact.
  let selectedAnswer: number | null = null;

  document.getElementById("submit-answer-btn")?.addEventListener("click", () => {
    if (selectedAnswer !== null) {
      document.dispatchEvent(new CustomEvent("question-answered", {
        detail: { answer: selectedAnswer }
      }));
    }
  });

  document.getElementById("skip-question-btn")?.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("question-skipped"));
  });

  (window as any).setSelectedAnswer = (answer: number) => {
    selectedAnswer = answer;
  };

  // Reset selection state whenever the modal opens fresh
  (window as any).resetSelectedAnswer = () => {
    selectedAnswer = null;
  };
</script>
