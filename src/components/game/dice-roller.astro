---
interface Props {
  playerColor: string;
}

const { playerColor } = Astro.props;
---

<div class="dice-roller flex flex-col items-center gap-3">
  <button
    id="roll-dice-btn"
    class="dice-button relative w-24 h-24 rounded-xl shadow-lg transition-all hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
    style={`background: linear-gradient(135deg, ${playerColor} 0%, ${playerColor}dd 100%);`}
  >
    <div id="dice-face" class="dice-face text-white text-4xl font-bold">
      🎲
    </div>
  </button>
  <p class="text-sm font-medium text-gray-700">Roll Dice</p>
</div>

<style>
  .dice-button {
    border: 3px solid rgba(0, 0, 0, 0.2);
  }

  .dice-button:hover {
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .dice-button.rolling {
    animation: shake 0.5s ease-in-out;
  }

  @keyframes shake {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-10deg); }
    75% { transform: rotate(10deg); }
  }

  .dice-face {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
</style>
