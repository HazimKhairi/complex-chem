---
import { cn } from "../../lib/utils";
import type { QuestionCardImage } from "../../lib/data/question-cards-image";

interface Props {
  card: QuestionCardImage;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { card, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full aspect-[7/5]",
  md: "w-full aspect-[7/5]",
  lg: "w-full aspect-[7/5]",
};

const difficultyColors = {
  easy: "border-green-500",
  medium: "border-yellow-500",
  hard: "border-red-500",
};

// Calculate background position for the image crop
// Each image has note on left, question on right
const getBackgroundPosition = (side: "note" | "question") => {
  // Left side = note (0%), Right side = question (100%)
  return side === "note" ? "0% center" : "100% center";
};
---

<div class={cn("question-flip-card-container", sizeClasses[size], className)}>
  <div class="question-flip-card w-full h-full">
    <!-- Front: Did you know? (Note) -->
    <div
      class={cn(
        "question-flip-card-face question-flip-card-front absolute inset-0 rounded-lg border-4 overflow-hidden",
        difficultyColors[card.difficulty],
      )}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/question-cards/${card.imageFile}'); background-position: ${getBackgroundPosition("note")}; background-size: 200%;`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip
      </div>
    </div>

    <!-- Back: Question -->
    <div
      class={cn(
        "question-flip-card-face question-flip-card-back absolute inset-0 rounded-lg border-4 overflow-hidden",
        difficultyColors[card.difficulty],
      )}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/question-cards/${card.imageFile}'); background-position: ${getBackgroundPosition("question")}; background-size: 200%;`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip back
      </div>
    </div>
  </div>
</div>

<style>
  .question-flip-card-container {
    perspective: 1000px;
    cursor: pointer;
  }

  .question-flip-card {
    transform-style: preserve-3d;
    transition: transform 0.6s;
    position: relative;
  }

  .question-flip-card-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .question-flip-card-back {
    transform: rotateY(180deg);
  }

  .question-flip-card-container.flipped .question-flip-card {
    transform: rotateY(180deg);
  }
</style>

<script>
  // Add click handlers to question flip cards
  document.addEventListener("DOMContentLoaded", () => {
    const containers = document.querySelectorAll(".question-flip-card-container");
    containers.forEach((container) => {
      container.addEventListener("click", () => {
        container.classList.toggle("flipped");
      });
    });
  });
</script>
