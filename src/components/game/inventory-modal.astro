---
---

<div id="inventory-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-gradient-to-r from-blue-600 to-purple-600 text-white p-4 rounded-t-2xl">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold">Your Ligand Collection 🧪</h2>
        <button id="close-inventory-btn" class="text-white hover:text-gray-200 text-3xl">&times;</button>
      </div>
    </div>

    <div class="p-6">
      <div id="inventory-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <!-- Ligand cards will be inserted here -->
      </div>
      <div id="inventory-empty" class="text-center py-12 text-gray-500 hidden">
        <p class="text-xl mb-2">🧪</p>
        <p>No ligands collected yet!</p>
        <p class="text-sm">Land on ligand tiles to collect them.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("inventory-modal");
  const closeBtn = document.getElementById("close-inventory-btn");

  // Open inventory
  document.addEventListener("open-inventory", () => {
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
  });

  // Close inventory
  closeBtn?.addEventListener("click", () => {
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  });

  // Close on outside click
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  });
</script>
