---
---

<div id="ligand-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-3 sm:p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-4 sm:p-6 text-center animate-bounce-in max-h-[90vh] overflow-y-auto">
    <div class="mb-3 sm:mb-4">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-2">Ligand Collected!</h2>
      <p class="text-sm sm:text-base text-gray-600">Click card to see details</p>
    </div>

    <div id="ligand-card-container" class="mb-4 sm:mb-6">
      <!-- Ligand flip card will be inserted here -->
    </div>

    <button id="continue-ligand-btn" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-2.5 sm:py-3 rounded-lg transition-colors text-sm sm:text-base">
      Continue Game →
    </button>
  </div>
</div>

<style>
  @keyframes bounce-in {
    0% {
      transform: scale(0.3);
      opacity: 0;
    }
    50% {
      transform: scale(1.05);
    }
    70% {
      transform: scale(0.9);
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .animate-bounce-in {
    animation: bounce-in 0.5s ease-out;
  }
</style>

<script>
  const modal = document.getElementById("ligand-modal");
  const continueBtn = document.getElementById("continue-ligand-btn");

  continueBtn?.addEventListener("click", () => {
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    document.dispatchEvent(new Event("ligand-continue"));
  });
</script>
