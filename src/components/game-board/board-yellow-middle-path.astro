    "path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:w-[22.5px] [&_td]:h-[22.5px] [&_td]:relative [&_img]:w-[9px] [&_img]:mx-auto [&_img]:relative [&_img]:z-10",
  )}
>
  <tr>
    <td
      class="r44 b31 y5 g18"
      style="background: #ef4444 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td class="y56 bg-yellow-300"></td>
    <td class="r32 b19 y45 g6"><span class="text-[8px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none">en</span></td>
  </tr>
  <tr>
    <td
