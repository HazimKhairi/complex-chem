---
import { cn } from "../../lib/utils";
import type { Ligand } from "../../lib/data/ligands";

interface Props {
  ligand: Ligand;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { ligand, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full aspect-[3/4]",
  md: "w-full aspect-[3/4]",
  lg: "w-full aspect-[3/4]",
};

// Calculate background position for the image crop
// Each image has logo on left, description on right
const getBackgroundPosition = (side: "logo" | "description") => {
  // Left side = logo (0%), Right side = description (100%)
  return side === "logo" ? "0% center" : "100% center";
};
---

<div class={cn("ligand-flip-card-container", sizeClasses[size], className)}>
  <div class="ligand-flip-card w-full h-full">
    <!-- Front: Logo -->
    <div
      class={cn(
        "ligand-flip-card-face ligand-flip-card-front absolute inset-0 rounded-lg border-4 overflow-hidden",
      )}
      style={`border-color: ${ligand.color}`}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/ligand-cards/${ligand.imageFile}'); background-position: ${getBackgroundPosition("logo")}; background-size: 200%;`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip
      </div>
    </div>

    <!-- Back: Description -->
    <div
      class={cn(
        "ligand-flip-card-face ligand-flip-card-back absolute inset-0 rounded-lg border-4 overflow-hidden",
      )}
      style={`border-color: ${ligand.color}`}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/ligand-cards/${ligand.imageFile}'); background-position: ${getBackgroundPosition("description")}; background-size: 200%;`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip back
      </div>
    </div>
  </div>
</div>

<style>
  .ligand-flip-card-container {
    perspective: 1000px;
    cursor: pointer;
  }

  .ligand-flip-card {
    transform-style: preserve-3d;
    transition: transform 0.6s;
    position: relative;
  }

  .ligand-flip-card-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .ligand-flip-card-back {
    transform: rotateY(180deg);
  }

  .ligand-flip-card-container.flipped .ligand-flip-card {
    transform: rotateY(180deg);
  }
</style>

<script>
  // Add click handlers to ligand flip cards
  document.addEventListener("DOMContentLoaded", () => {
    const containers = document.querySelectorAll(".ligand-flip-card-container");
    containers.forEach((container) => {
      container.addEventListener("click", () => {
        container.classList.toggle("flipped");
      });
    });
  });
</script>
