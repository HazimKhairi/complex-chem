  .l2-util-icon:hover { background: rgba(255,255,255,0.28); transform: translateY(-1px); }
  .l2-util-icon svg { width: 16px; height: 16px; }

  /* ============================================================
     Bouncy "+N points" toast — shown after a correct answer.
     ============================================================ */
  .l2-points-toast {
    position: fixed;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    animation: l2-toast-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }
  .l2-points-toast-inner {
    background: linear-gradient(135deg, #fde68a 0%, #f59e0b 70%, #d97706 100%);
    color: #78350f;
    padding: 36px 60px;
    border-radius: 32px;
    box-shadow: 0 22px 56px rgba(0,0,0,0.36), inset 0 -8px 0 rgba(0,0,0,0.14);
    text-align: center;
    border: 6px solid #fff;
    position: relative;
  }
  /* Big radiant glow halo behind the toast. */
  .l2-points-toast-inner::before {
    content: "";
    position: absolute;
    inset: -56px;
    background: radial-gradient(circle, rgba(253, 224, 71, 0.65) 0%, rgba(253, 224, 71, 0) 70%);
    border-radius: 50%;
    z-index: -1;
    animation: l2-toast-glow 1.6s ease-in-out infinite;
  }
  .l2-points-toast-label {
    display: block;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    opacity: 0.95;
  }
  .l2-points-toast-num {
    display: block;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    font-size: 4.8rem;
    line-height: 1.05;
    margin-top: 10px;
    text-shadow: 0 3px 0 rgba(255,255,255,0.5), 0 5px 12px rgba(120, 53, 15, 0.35);
  }
  .l2-points-toast-num--small {
    font-size: 3.2rem; /* "Correct!" wraps slimmer than "+N pts" */
  }
  /* Sparkle stars positioned around the toast. Bigger + more of them
     per Hazim 2026-05-10 spec ("sparkling tu nak lagi besar"). The
     drop-shadow gives a heavy gold halo so each star reads from a
     distance. */
  .l2-toast-spark {
    position: absolute;
    color: #fde047;
    filter: drop-shadow(0 0 14px rgba(253, 224, 71, 1)) drop-shadow(0 0 24px rgba(245, 158, 11, 0.85));
    animation: l2-toast-sparkle 1.2s ease-in-out infinite;
  }
  .l2-toast-spark svg { width: 100%; height: 100%; display: block; }
  .l2-toast-spark--tl { top: -48px; left: -48px;  width: 72px; height: 72px; animation-delay: 0s; }
  .l2-toast-spark--tr { top: -54px; right: -42px; width: 60px; height: 60px; animation-delay: 0.2s; }
  .l2-toast-spark--bl { bottom: -44px; left: -38px;  width: 64px; height: 64px; animation-delay: 0.4s; }
  .l2-toast-spark--br { bottom: -54px; right: -50px; width: 80px; height: 80px; animation-delay: 0.6s; }
  .l2-toast-spark--t  { top: -68px; left: 50%; transform: translateX(-50%); width: 56px; height: 56px; animation-delay: 0.3s; }
  .l2-toast-spark--l  { top: 40%; left: -56px; width: 50px; height: 50px; animation-delay: 0.15s; }
  .l2-toast-spark--r  { top: 40%; right: -56px; width: 50px; height: 50px; animation-delay: 0.55s; }
  @keyframes l2-toast-sparkle {
    0%, 100% { transform: scale(0.8) rotate(0deg); opacity: 0.4; }
    50%      { transform: scale(1.4) rotate(180deg); opacity: 1; }
  }
  .l2-toast-spark--t { /* override transform to keep horizontal centring */ }
  .l2-toast-spark--t {
    animation-name: l2-toast-sparkle-center;
  }
  @keyframes l2-toast-sparkle-center {
    0%, 100% { transform: translateX(-50%) scale(0.8) rotate(0deg); opacity: 0.4; }
    50%      { transform: translateX(-50%) scale(1.4) rotate(180deg); opacity: 1; }
  }
  @keyframes l2-toast-glow {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.12); }
  }
  /* Q4 image-only geometry cards. White card, big image, no labels.
     States mirror the kahoot button so selected/correct/wrong reads
     consistently across the wizard. */
  .geo-img-card {
    position: relative;
    background: #fff;
    border: 3px solid #cbd5e1;
    border-radius: 18px;
    padding: 12px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    box-shadow: 0 5px 0 rgba(0,0,0,0.08), 0 8px 16px rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .geo-img-card img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }
  .geo-img-card:hover {
    border-color: #3b82f6;
    transform: translateY(-2px);
    box-shadow: 0 7px 0 rgba(0,0,0,0.10), 0 12px 22px rgba(0,0,0,0.10);
  }
  .geo-img-card:disabled { cursor: default; }
  /* Picture-pick selected — matches the kahoot-button selected pattern:
     navy band → gold halo → check badge. White-on-image backgrounds
     made the previous gold outline disappear over yellow molecules
     (4.png, 7.png, 9.png). This layered approach is colour-blind safe
     and pops against any image colour. */
  .geo-img-card[data-state="selected"] {
    outline: 5px solid #ffffff;
    outline-offset: 4px;
    transform: translateY(-4px) scale(1.06);
    box-shadow:
      0 0 0 9px #0f172a,
      0 0 0 16px rgba(253, 224, 71, 0.55),
      0 18px 28px rgba(0,0,0,0.30);
    border-color: #0f172a;
    z-index: 2;
    animation: l2-kahoot-pulse 1.4s ease-in-out infinite;
  }
  .geo-img-card[data-state="selected"]::after {
    content: "\2713";
    position: absolute;
    top: -14px;
    right: -14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fde047;
    color: #78350f;
    font-weight: 900;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.30);
    border: 3px solid #fff;
    z-index: 3;
  }
  .geo-img-card[data-state="correct"] {
    border-color: #22c55e;
    box-shadow: 0 5px 0 #15803d, 0 0 0 4px rgba(34, 197, 94, 0.25);
    background: #f0fdf4;
  }
  .geo-img-card[data-state="wrong"] {
    border-color: #ef4444;
    box-shadow: 0 5px 0 #991b1b, 0 0 0 4px rgba(239, 68, 68, 0.22);
    background: #fef2f2;
    animation: l2-kahoot-shake 0.4s;
  }
  .geo-img-card[data-state="faded"] {
    opacity: 0.35;
    pointer-events: none;
    filter: grayscale(0.6);
  }

  /* Armed inventory ligand — research-driven (NN/g, Microsoft Visual
     Feedback, Smart Interface Design Patterns): the previous outline
     + check sat too quietly on a 54 px tile below the dominant 3D
     canvas — the player's eye was on the canvas, not the strip.
     Stronger pulse + animation pulls the eye, AND a cursor-following
     ghost preview travels into the canvas. Hazim 2026-05-10:
     "tak nampak player pilih mana". */
  .lig-drag-card[data-armed="true"] {
    outline: 4px solid #fbbf24;
    outline-offset: 3px;
    box-shadow: 0 0 0 8px rgba(251, 191, 36, 0.35), 0 8px 24px rgba(0,0,0,0.25);
    position: relative;
    z-index: 5;
    border-color: #fbbf24 !important;
    animation: l2-armed-pulse 1.1s ease-in-out infinite;
  }
  @keyframes l2-armed-pulse {
    0%, 100% { transform: translateY(0)    scale(1); }
    50%      { transform: translateY(-4px) scale(1.06); }
  }
  .lig-drag-card[data-armed="true"]::after {
    content: "\2713";
    position: absolute;
    top: -10px;
    right: -10px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #fbbf24;
    color: #78350f;
    font-weight: 900;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 8px rgba(0,0,0,0.30);
    border: 2px solid #fff;
  }

  /* Body cursor change while a ligand is armed — global "I'm holding
     something" feedback so the cursor looks intentional inside the
     3D canvas too. */
  body.l2-arming, body.l2-arming * { cursor: crosshair !important; }

  /* Cursor-following ghost preview. Shows a yellow-ringed pill with
     the ligand's sphere-color dot + name attached to the cursor while
     armed. This is the LOAD-BEARING fix — research finding: the cue
     must travel with the cursor into the 3D scene rather than sit
     isolated in the inventory strip. */
  #l2-arm-ghost {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    transform: translate(-50%, calc(-100% - 14px)) rotate(-3deg);
    background: #fff;
    border: 3px solid #fbbf24;
    border-radius: 14px;
    box-shadow: 0 8px 22px rgba(0,0,0,0.35);
    padding: 8px 14px;
    display: none;
    z-index: 9999;
    font: 700 0.95rem 'Fredoka', system-ui, sans-serif;
    color: #78350f;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }
  #l2-arm-ghost[data-on="1"] { display: inline-flex; }
  .l2-arm-ghost-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: inset 0 -3px 0 rgba(0,0,0,0.18), 0 0 0 2px #fff, 0 2px 6px rgba(0,0,0,0.25);
  }
  .l2-arm-ghost-name { font-size: 1rem; }

  /* Q5 chemistry formula box — research-driven (MDN <wbr>, CSS-Tricks
     box-decoration-break, Modern CSS container query units, Piccalilli
     fit-text). Hazim 2026-05-10: "dalam bracket tu kalau ade byk ligand
     tk nampak sepenuhnya ligand". The previous `clamp(.., 2vw, ..)`
     scaled to viewport, so a wide screen with a narrow pill still
     overflowed. `9cqi` (container query inline) scales to the formula
     pill itself. `word-break: keep-all` guarantees breaks never fall
     mid-bracket, and `text-wrap: balance` distributes a 2-line wrap
     evenly. ResizeObserver below shrinks the last 5 % programmatically
     when the natural fit still overflows. */
  .l2-formula-box {
    container-type: inline-size;
  }
  .l2-formula {
    font-size: clamp(1rem, 9cqi, 2.4rem);
    line-height: 1.15;
    text-align: center;
    text-wrap: balance;
    word-break: keep-all;
    overflow-wrap: normal;
    hyphens: none;
    -webkit-box-decoration-break: clone;
            box-decoration-break: clone;
    max-width: 100%;
    overflow: hidden;
  }
  .l2-formula .nb { white-space: nowrap; }

  .l2-points-toast-fade { animation: l2-toast-out 0.6s ease-in forwards; }
  @keyframes l2-toast-pop {
    0%   { opacity: 0; transform: translateX(-50%) scale(0.4) rotate(-8deg); }
    55%  { opacity: 1; transform: translateX(-50%) scale(1.12) rotate(2deg); }
    80%  { transform: translateX(-50%) scale(0.96) rotate(-1deg); }
    100% { opacity: 1; transform: translateX(-50%) scale(1) rotate(0deg); }
  }
  @keyframes l2-toast-out {
    from { opacity: 1; transform: translateX(-50%) scale(1); }
    to   { opacity: 0; transform: translateX(-50%) scale(0.95) translateY(-12px); }
  }
</style>

