---
---

<div id="fate-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-3 sm:p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-4 sm:p-6 text-center max-h-[90vh] overflow-y-auto">
    <div class="mb-3 sm:mb-4">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-2">Fate Card!</h2>
      <p class="text-sm sm:text-base text-gray-600">Destiny has chosen...</p>
    </div>

    <div id="fate-card-container" class="mb-4 sm:mb-6">
      <!-- Fate card will be inserted here -->
    </div>

    <button id="continue-fate-btn" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-2.5 sm:py-3 rounded-lg transition-colors text-sm sm:text-base">
      Accept Fate →
    </button>
  </div>
</div>

<script>
  const modal = document.getElementById("fate-modal");
  const continueBtn = document.getElementById("continue-fate-btn");

  // Effects that open a follow-up modal and need the player to choose
  // something — they fire "fate-continue" themselves once the user is
  // done, so we MUST NOT fire it on Accept (it would advance the turn
  // before the player even sees the second modal).
  const INTERACTIVE_EFFECTS = ["swap-card"];

  continueBtn?.addEventListener("click", () => {
    if (!modal) {
      document.dispatchEvent(new Event("fate-continue"));
      return;
    }

    // Apply fate card effect before closing modal
    const playerId = parseInt(modal.dataset.playerId || "0");
    const fateEffect = modal.dataset.fateEffect;
    const fateValue = parseInt(modal.dataset.fateValue || "0");
    const fateTitle = modal.dataset.fateTitle;

    console.log(`🔺 [FATE] Applying fate: ${fateTitle} to Player ${playerId}`);

    // Points are ONLY awarded for effects that actually mean "points".
    // Other effects use `value` for a different purpose (spaces to move,
    // ligands to gain/give, etc.) and must NOT be treated as points.
    const POINTS_EFFECTS = ["point-booster", "minus"];
    if (POINTS_EFFECTS.includes(fateEffect) && fateValue !== 0 && window.GameMechanics) {
      window.GameMechanics.awardPoints(playerId, fateValue, 'fate');
      console.log(`💰 [FATE] Player ${playerId} ${fateValue > 0 ? 'gained' : 'lost'} ${Math.abs(fateValue)} points`);
      // Show a toast — Hazim 2026-05-11 reported point/minus fate
      // mutations were silent (UIAnimations was skipped on this page).
      if (window.FateEffectHandler && typeof window.FateEffectHandler.showNotification === 'function') {
        const sign = fateValue > 0 ? '+' : '−';
        const msg = `${sign}${Math.abs(fateValue)} points for Player ${playerId}`;
        window.FateEffectHandler.showNotification(msg, fateValue > 0 ? 'success' : 'error');
      }
    }

    // Apply the card's actual behaviour (gain ligand, move forward, swap, etc.)
    if (fateEffect && window.FateEffectHandler) {
      window.FateEffectHandler.applyEffect(playerId, fateEffect, fateValue);
    } else if (!window.FateEffectHandler) {
      console.warn('⚠️ FateEffectHandler not available, effects will not run');
    }

    modal.classList.add("hidden");
    modal.classList.remove("flex");

    // For interactive effects (swap-card), the follow-up modal will fire
    // fate-continue via swap-complete / swap-cancelled when the user is
    // done. Firing it now would double-advance the turn.
    if (!INTERACTIVE_EFFECTS.includes(fateEffect)) {
      document.dispatchEvent(new Event("fate-continue"));
    } else {
      console.log(`⏸️  [FATE] ${fateEffect} is interactive — deferring fate-continue until swap-complete/cancelled`);
    }
  });

  // Listen for swap completion
  document.addEventListener("swap-complete", () => {
    console.log("🔄 [FATE] Swap complete - continuing game");
    document.dispatchEvent(new Event("fate-continue"));
  });

  // Listen for swap cancellation
  document.addEventListener("swap-cancelled", () => {
    console.log("❌ [FATE] Swap cancelled - continuing game");
    document.dispatchEvent(new Event("fate-continue"));
  });
</script>
