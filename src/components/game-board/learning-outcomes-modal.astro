---
/*
 * Learning Outcomes popup — shown immediately after the player dismisses
 * the objective/rules modal. Reminds students of the 4 takeaways before
 * the 3,2,1 countdown starts. Listens for `objective-modal-dismissed`,
 * then dispatches `game-objective-dismissed` once the player clicks
 * "Let's Play" so the countdown can fire.
 */

const OUTCOMES = [
  "Identify ligands and their types",
  "Determine the coordination number",
  "Classify complexes (cation, anion, neutral)",
  "Predict the geometry of complexes",
];
---

<div
  id="learning-outcomes-modal"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4"
>
  <div class="relative w-full max-w-xl">
    <!-- Decorative bunting -->
    <svg class="absolute -top-6 left-0 right-0 w-full h-10 pointer-events-none opacity-90" viewBox="0 0 600 40" fill="none" aria-hidden="true">
      <path d="M0,5 Q150,30 300,12 T600,8" stroke="#fde68a" stroke-width="1.5" stroke-linecap="round" />
      <circle cx="80" cy="18" r="3" fill="#fbbf24" />
      <circle cx="180" cy="22" r="3" fill="#f97316" />
      <circle cx="280" cy="14" r="3" fill="#fbbf24" />
      <circle cx="380" cy="20" r="3" fill="#f97316" />
      <circle cx="480" cy="12" r="3" fill="#fbbf24" />
    </svg>

    <!-- Top-right floating dice -->
    <div class="absolute -top-3 -right-3 sm:-top-5 sm:-right-5 z-10 rotate-12">
      <div class="grid grid-cols-3 gap-0.5 w-12 h-12 sm:w-14 sm:h-14 bg-white rounded-lg shadow-xl border-2 border-gray-200 p-1.5">
        <span class="bg-gray-900 rounded-full"></span>
        <span></span>
        <span class="bg-gray-900 rounded-full"></span>
        <span></span>
        <span class="bg-gray-900 rounded-full"></span>
        <span></span>
        <span class="bg-gray-900 rounded-full"></span>
        <span></span>
        <span class="bg-gray-900 rounded-full"></span>
      </div>
    </div>

    <!-- Card -->
    <div class="relative bg-gradient-to-br from-indigo-900 via-blue-900 to-indigo-950 rounded-3xl shadow-2xl border-4 border-amber-300/40 overflow-hidden">
      <!-- Confetti dots -->
      <div class="absolute inset-0 pointer-events-none opacity-50">
        <span class="absolute top-3 left-1/4 w-1.5 h-3 bg-pink-400 rounded-sm rotate-12"></span>
        <span class="absolute top-6 right-1/3 w-1.5 h-3 bg-yellow-300 rounded-sm -rotate-12"></span>
        <span class="absolute bottom-4 left-12 w-1.5 h-3 bg-emerald-400 rounded-sm rotate-45"></span>
        <span class="absolute bottom-6 right-10 w-1.5 h-3 bg-purple-400 rounded-sm -rotate-45"></span>
        <span class="absolute top-1/2 left-3 w-1 h-1 bg-cyan-300 rounded-full"></span>
        <span class="absolute bottom-1/3 right-4 w-1 h-1 bg-amber-300 rounded-full"></span>
      </div>

      <!-- Inner panel -->
      <div class="relative bg-white rounded-2xl m-4 sm:m-6 p-6 sm:p-8 shadow-inner">
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-center text-sky-500 uppercase mb-1">
          Learning Outcomes
        </h2>
        <p class="text-center text-sm text-gray-600 mb-5 sm:mb-6">
          After completing this game, players will be able to:
        </p>

        <ul class="space-y-3">
          {OUTCOMES.map((text, i) => (
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 mt-0.5 w-7 h-7 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 text-white text-xs font-black flex items-center justify-center shadow">
                {i + 1}
              </span>
              <span class="text-base sm:text-lg text-gray-800 font-medium leading-snug">
                {text}
              </span>
            </li>
          ))}
        </ul>

        <div class="mt-6 sm:mt-8 flex justify-center">
          <button
            id="learning-outcomes-continue"
            type="button"
            class="px-8 py-3 rounded-xl bg-gradient-to-r from-amber-400 to-orange-500 hover:from-amber-500 hover:to-orange-600 text-white font-black text-base shadow-lg transform transition-transform hover:scale-105 active:scale-95"
          >
            Let's Play
          </button>
        </div>
      </div>
    </div>

    <!-- Bottom-left molecule decoration -->
    <svg class="absolute -bottom-4 -left-4 w-16 h-16 sm:w-20 sm:h-20 pointer-events-none drop-shadow-lg" viewBox="0 0 80 80" aria-hidden="true">
      <line x1="40" y1="40" x2="20" y2="22" stroke="#9ca3af" stroke-width="3" />
      <line x1="40" y1="40" x2="60" y2="22" stroke="#9ca3af" stroke-width="3" />
      <line x1="40" y1="40" x2="40" y2="68" stroke="#9ca3af" stroke-width="3" />
      <circle cx="40" cy="40" r="9" fill="#cbd5e1" stroke="#475569" stroke-width="1.5" />
      <circle cx="20" cy="22" r="7" fill="#ef4444" />
      <circle cx="60" cy="22" r="7" fill="#10b981" />
      <circle cx="40" cy="68" r="7" fill="#ef4444" />
    </svg>
  </div>
</div>

<script>
  const modal = document.getElementById("learning-outcomes-modal");
  const continueBtn = document.getElementById("learning-outcomes-continue");

  function show() {
    if (!modal) return;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  function dismiss() {
    if (!modal) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    // Hand off to the countdown.
    document.dispatchEvent(new CustomEvent("game-objective-dismissed"));
  }

  document.addEventListener("objective-modal-dismissed", show, { once: true });
  continueBtn?.addEventListener("click", dismiss);
</script>
