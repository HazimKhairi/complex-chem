---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

import { cn } from "../lib/utils";
import SoloOptions from "../components/pass-and-play/solo-options.astro";
import OneVsOneOptions from "../components/pass-and-play/one-vs-one-options.astro";
import OneVsTwoOptions from "../components/pass-and-play/one-vs-two-options.astro";
import OneVsThreeOptions from "../components/pass-and-play/one-vs-three-options.astro";
import SelectGameMode from "../components/select-game-mode.astro";
import LoadingScreen from "../components/loading-screen.astro";
---

<Layout>
  <LoadingScreen />
  <main class="flex justify-center items-center min-h-screen p-2 bg-azure w-[95%] mx-auto">
    <div class="rounded-2xl shadow-md bg-white px-5 sm:px-10 py-5 w-full max-w-lg">
      <SelectGameMode includeSolo={true} />
      <SoloOptions />
      <OneVsOneOptions />
      <OneVsTwoOptions />
      <OneVsThreeOptions />
    </div>
  </main>
</Layout>

<!-- AudioManager needed for character-picker hover/select SFX -->
<script is:inline src="/scripts/audio-manager.js"></script>

<script>
  sessionStorage.setItem("computer", "false");
</script>
