---
import ShareButton from "../components/share-button.astro";
import Layout from "../layouts/Layout.astro";
import GameButton from "../components/game-button.astro";
---

<Layout>
  <main class="flex justify-center items-center h-dvh p-2">
    <div class="rounded-2xl shadow-md bg-white px-5 sm:px-10 py-5 w-full max-w-lg space-y-5">
      <div>
        <img
          class="block mx-auto h-40 mb-4"
          draggable="false"
          src="/complex-chem-logo.png"
          alt="Complex Chem Quest logo"
          loading="eager"
        />
        <h2 class="text-center font-bold text-2xl">
          <span class="text-[#DC143C]">COMPLEX-CHEM</span>
          <span class="text-[#0066CC]"> QUEST</span>
        </h2>
        <p class="text-center text-gray-600 text-sm mt-1">Digital Smart Board</p>
      </div>

      <div class="grid grid-cols-2 gap-8">
        <a href="/pass-and-play">
          <GameButton id="pass-and-play" class="w-full" text="Pass & Play" color="#629e76" /></a
        >
        <div class="opacity-50 cursor-not-allowed">
          <GameButton id="computer" class="w-full pointer-events-none" text="Computer" color="#3ebbf7" />
        </div>
      </div>

      <div class="opacity-50 cursor-not-allowed pointer-events-none">
        <p class="text-center font-medium mb-5">Share Complex Chem Quest with your friends</p>
        <ShareButton />
      </div>

      <p class="text-center text-gray-600">
        Created by <span class="font-medium text-gray-800">HazimDev</span>
      </p>
    </div>
  </main>
</Layout>

<script>
  sessionStorage.clear();
</script>
