    "[&_td]:border [&_td]:border-black [&_td]:relative",
    "[&_td]:w-[36px] [&_td]:h-[36px] [&_td]:sm:w-[38px] [&_td]:sm:h-[38px] [&_td]:md:w-[40px] [&_td]:md:h-[40px] [&_td]:lg:w-[42px] [&_td]:lg:h-[42px]",
    "[&_img]:w-[14px] [&_img]:sm:w-[15px] [&_img]:md:w-4 [&_img]:lg:w-[18px]",
    "[&_img]:mx-auto [&_img]:relative [&_img]:z-20 [&_img]:drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]",
    "border-collapse m-0 p-0",
  )}
>
  <tr>
    <td class="r10 b49 y23 g36"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
