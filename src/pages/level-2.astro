---
import Layout from "../layouts/Layout.astro";
import GameSettingsMenu from "../components/game-settings-menu.astro";
import Level2IntroModal from "../components/game-board/level2-intro-modal.astro";
import IndicatorPanel from "../components/game-board/indicator-panel.astro";
import LoadingScreen from "../components/loading-screen.astro";
import LevelTwoPodium from "../components/game-board/level2-podium.astro";
---

<Layout>
  <LoadingScreen />
  <LevelTwoPodium />
  <GameSettingsMenu />
  <Level2IntroModal />
  <IndicatorPanel />
  <main class="l2-main h-dvh px-3 py-2 flex flex-col items-center gap-2 overflow-hidden relative">
    <!-- TOP HUD — gradient game bar with brand, step indicator, score chip -->
    <div class="w-full max-w-6xl rounded-2xl shadow-lg overflow-hidden flex-shrink-0 bg-gradient-to-r from-[#1e3a8a] via-[#2563eb] to-[#1e40af]">
      <div class="flex items-center justify-between gap-3 px-4 py-2">
        <!-- Brand cluster + Kahoot-mock utility icons -->
        <div class="flex items-center gap-2 min-w-0">
          <div class="w-9 h-9 rounded-xl bg-amber-400 flex items-center justify-center font-black text-blue-900 text-base shadow-md">
            L2
          </div>
          <div class="min-w-0">
            <p class="text-white font-black text-sm sm:text-base leading-tight truncate" style="font-family: 'Fredoka', sans-serif;">
              Build Your Complex
            </p>
            <p id="player-info" class="text-blue-100 text-[10px] truncate"></p>
          </div>
          <!-- Top-left utility icons (mute, music, restart, info). -->
          <span class="l2-util-icons hidden sm:inline-flex">
            <button id="l2-util-mute" type="button" class="l2-util-icon" title="Mute / unmute SFX">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M19 12c0-1.66-.93-3.1-2.3-3.83"/><path d="M22 12c0-3.31-2-6.18-4.85-7.41"/></svg>
            </button>
            <button id="l2-util-music" type="button" class="l2-util-icon" title="Music">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            </button>
            <button id="l2-util-restart" type="button" class="l2-util-icon" title="Restart Level 2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
            </button>
            <button id="l2-util-info" type="button" class="l2-util-icon" title="How to play">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </button>
          </span>
        </div>

        <!-- Step Indicator (5 stages) -->
        <div class="hidden sm:flex items-center justify-center gap-0 flex-1 max-w-md">
          {[1, 2, 3, 4, 5].map((n, i) => (
            <>
              <div
                class="step-dot flex items-center justify-center rounded-full text-white font-bold text-xs shrink-0"
                data-step={n}
              >
                {n}
              </div>
              {i < 4 && <div class="step-line flex-1" />}
            </>
          ))}
        </div>

        <!-- Score chip — gold leaderboard vibe, BIG numerals so the
             score is the loudest thing on the HUD bar. -->
        <div class="flex items-center gap-2 px-4 py-2 rounded-2xl bg-gradient-to-r from-amber-400 to-yellow-500 shadow-lg ring-2 ring-amber-200">
          <svg class="w-5 h-5 text-amber-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.39 7.36H22l-6.19 4.5L18.2 21 12 16.27 5.8 21l2.39-7.14L2 9.36h7.61z"/>
          </svg>
          <span class="text-[10px] font-black text-amber-900 uppercase tracking-wider hidden sm:inline">Score</span>
          <span id="hud-total-score" class="text-2xl sm:text-3xl font-black text-blue-900 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
        </div>
      </div>

      <!-- Step Indicator (mobile fallback row) -->
      <div class="sm:hidden flex items-center justify-center gap-0 px-4 pb-2 max-w-md mx-auto">
        {[1, 2, 3, 4, 5].map((n, i) => (
          <>
            <div
              class="step-dot flex items-center justify-center rounded-full text-white font-bold text-xs shrink-0"
              data-step={n}
            >
              {n}
            </div>
            {i < 4 && <div class="step-line flex-1" />}
          </>
        ))}
      </div>
    </div>

    <!-- Collected ligands HUD rail -->
    <div
      id="collected-ligands-strip"
      class="w-full max-w-6xl bg-white rounded-2xl shadow-md border-2 border-blue-100 px-3 py-2 hidden flex-shrink-0"
    >
      <div class="flex items-center gap-2 overflow-x-auto">
        <span class="text-[10px] font-black uppercase tracking-wider text-blue-700 flex-shrink-0">Inventory</span>
        <span class="text-[10px] text-gray-400 flex-shrink-0">·</span>
        <span class="text-[10px] text-gray-500 flex-shrink-0"><span id="cl-count">0</span> ligand(s)</span>
        <span class="text-[10px] text-gray-300 flex-shrink-0">|</span>
        <div id="collected-ligands-list" class="flex flex-nowrap gap-1.5 overflow-x-auto"></div>
      </div>
    </div>

    <!-- Two-column workspace: step content (left) + 3D builder (right
         when visible). When the builder is hidden the step container
         expands to use the full width. -->
    <div id="l2-workspace" class="w-full max-w-6xl flex-1 min-h-0 grid grid-cols-1 gap-3 lg:grid-cols-1" data-builder-visible="false">
      <!-- Step Content Container — hugs its own content height
           (self-start) so a short message like "Try again" doesn't
           leave a giant empty white card. Caps at the available
           viewport height, scrolls internally if content is taller. -->
      <div
        id="step-container"
        class="bg-white rounded-2xl shadow-md p-4 sm:p-5 self-start w-full max-h-full overflow-y-auto"
      >
        <p class="text-gray-400 text-center mt-20">Loading...</p>
      </div>

      <!-- 3D Canvas (hidden until Step 5). max-h-full + min-h-0 keep
           the whole card capped to its grid cell so the score bar
           never gets pushed below the viewport. -->
      <div id="builder-container" class="hidden min-h-0 max-h-full flex flex-col">
        <div class="bg-white rounded-2xl shadow-md overflow-hidden flex-1 flex flex-col min-h-0 max-h-full relative">
          <!-- HUD overlay over the 3D canvas: chemistry notation
               [M(L)n…]ᶜʰᵃʳᵍᵉ on the left, "Charge: 2+" pill on the
               right. Populated by renderStep3 in level-2-game.js. -->
          <div id="builder-hud" class="absolute top-2 left-2 right-2 z-10 flex items-start justify-between gap-2 pointer-events-none">
            <div id="builder-formula" class="px-3 py-1.5 rounded-xl bg-white/90 backdrop-blur shadow-md border-2 border-blue-200 text-blue-900 font-bold text-sm tabular-nums"
                 style="font-family:'Fredoka',system-ui,sans-serif;">
              <!-- e.g. [Cr(NH₃)₃(H₂O)₃] -->
            </div>
            <div id="builder-charge-pill" class="px-3 py-1.5 rounded-xl bg-gradient-to-r from-amber-400 to-orange-500 shadow-md text-blue-900 text-xs font-black uppercase tracking-wider hidden">
              <!-- e.g. CHARGE 2+ -->
            </div>
          </div>
          <canvas id="three-canvas" class="w-full flex-1 min-h-0" style="touch-action:none;"></canvas>
          <div class="px-3 py-1.5 border-t border-gray-100 flex-shrink-0">
            <p class="text-[10px] text-gray-500 uppercase tracking-wide mb-1">Your Ligands — drag onto empty slots</p>
            <div id="ligand-inventory" class="flex flex-wrap gap-1.5 justify-center min-h-[36px]"></div>
          </div>
          <div class="px-3 py-1.5 border-t border-gray-100 flex justify-between items-center flex-shrink-0">
            <div class="text-xs text-gray-600">Slots filled: <strong id="slots-filled">0</strong> / <strong id="slots-total">0</strong></div>
            <div class="flex gap-2">
              <button id="btn-reset-3d" class="px-3 py-1.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 text-xs font-semibold">Reset</button>
              <button id="btn-submit-3d" class="px-3 py-1.5 rounded-lg bg-[#4187a0] text-white font-semibold text-xs hover:bg-[#357a91] disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed" disabled>Submit</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Score Bar — three pill badges with BIG Fredoka numerals.
         "Score tu nak besar" — Hazim spec. -->
    <div class="w-full max-w-6xl flex gap-2 sm:gap-3 flex-shrink-0">
      <div class="flex-1 bg-white border-2 border-blue-200 rounded-2xl px-3 py-2 flex items-center justify-between shadow-md">
        <span class="text-[10px] sm:text-xs font-black text-blue-700 uppercase tracking-widest">Level 1</span>
        <span id="l1-score" class="text-xl sm:text-3xl font-black text-blue-700 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
      <div class="flex-1 bg-white border-2 border-emerald-200 rounded-2xl px-3 py-2 flex items-center justify-between shadow-md">
        <span class="text-[10px] sm:text-xs font-black text-emerald-700 uppercase tracking-widest">Level 2</span>
        <span id="l2-score" class="text-xl sm:text-3xl font-black text-emerald-700 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
      <div class="flex-[1.2] bg-gradient-to-r from-amber-400 to-orange-500 rounded-2xl px-3 py-2 flex items-center justify-between shadow-lg ring-2 ring-amber-200">
        <span class="text-[10px] sm:text-xs font-black text-orange-900 uppercase tracking-widest">Total</span>
        <span id="total-score" class="text-2xl sm:text-4xl font-black text-blue-900 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
    </div>
  </main>

  <!-- Mirror total-score updates into the HUD chip too -->
  <script is:inline>
    (function () {
      var src = document.getElementById('total-score');
      var dst = document.getElementById('hud-total-score');
      if (!src || !dst) return;
      var obs = new MutationObserver(function () { dst.textContent = src.textContent; });
      obs.observe(src, { childList: true, characterData: true, subtree: true });
    })();
  </script>

  <!-- Wire the 4 Kahoot-mock utility icons. Mute toggles AudioManager
       SFX volume, Music toggles BGM, Restart wipes Level 2 state and
       reloads, Info re-shows the objective intro modal. -->
  <script is:inline>
    (function () {
      var muteBtn  = document.getElementById('l2-util-mute');
      var musicBtn = document.getElementById('l2-util-music');
      var restart  = document.getElementById('l2-util-restart');
      var infoBtn  = document.getElementById('l2-util-info');

      muteBtn && muteBtn.addEventListener('click', function () {
        var muted = localStorage.getItem('game-muted') === 'true';
        localStorage.setItem('game-muted', muted ? 'false' : 'true');
        muteBtn.style.opacity = muted ? '1' : '0.5';
      });
      // Reflect current state on first paint.
      if (muteBtn && localStorage.getItem('game-muted') === 'true') muteBtn.style.opacity = '0.5';

      musicBtn && musicBtn.addEventListener('click', function () {
        if (!window.AudioManager) return;
        if (window.__l2Music) {
          window.AudioManager.stopBGM && window.AudioManager.stopBGM();
          window.__l2Music = false;
          musicBtn.style.opacity = '0.5';
        } else {
          window.AudioManager.startBGM && window.AudioManager.startBGM();
          window.__l2Music = true;
          musicBtn.style.opacity = '1';
        }
      });

      restart && restart.addEventListener('click', function () {
        if (!confirm('Restart Level 2? Your current progress will be lost.')) return;
        sessionStorage.removeItem('level2-state');
        sessionStorage.removeItem('level2-intro-seen');
        window.location.reload();
      });

      infoBtn && infoBtn.addEventListener('click', function () {
        var modal = document.getElementById('level2-intro-modal');
        if (!modal) return;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });
    })();
  </script>

  <script is:inline>
    if (!sessionStorage.getItem("game-state")) {
      window.location.href = "/pass-and-play";
    }
  </script>
  <!-- three.js pinned to r147 — last release with classic
       examples/js/controls/OrbitControls.js. r0.160 dropped that
       folder which 404'd and broke the 3D builder. -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.147.0/examples/js/controls/OrbitControls.js"></script>
  <script is:inline src="/scripts/audio-manager.js"></script>
  <script is:inline src="/scripts/joyride.js"></script>
  <script is:inline src="/scripts/level-2-3d-builder.js"></script>
  <script is:inline src="/scripts/level-2-game.js"></script>
  <script is:inline src="/scripts/auto-play.js"></script>
  <script>
    // Play Level 2 intro chime on first user interaction (autoplay policy safe)
    (function () {
      let played = false;
      function playOnce() {
        if (played) return;
        played = true;
        if (window.AudioManager) window.AudioManager.play("level-2-start");
        document.removeEventListener("click", playOnce);
        document.removeEventListener("keydown", playOnce);
      }
      document.addEventListener("click", playOnce, { once: false });
      document.addEventListener("keydown", playOnce, { once: false });
    })();
  </script>
</Layout>

<!-- Game-feel typeface for the L2 HUD heading -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&display=swap" />

<style is:global>
  /* is:global so the dynamic showPointsToast() element + the JS-injected
     step content can pick up these selectors. Scoped styles get a build-
     time hash that runtime-created elements never have. */

  /* Step indicator inside the dark HUD bar — small, glowing pills */
  .step-dot {
    width: 26px;
    height: 26px;
    background-color: rgba(255, 255, 255, 0.18);
    border: 2px solid rgba(255, 255, 255, 0.25);
    transition: background-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .step-dot.active {
    background-color: #fbbf24;
    color: #1e3a8a !important;
    border-color: #fde68a;
    transform: scale(1.18);
    box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.25);
  }
  .step-dot.done {
    background-color: #10b981;
    border-color: #6ee7b7;
  }
  .step-line {
    height: 3px;
    background-color: rgba(255, 255, 255, 0.2);
    transition: background-color 0.3s;
    margin: 0 2px;
    border-radius: 2px;
  }
  .step-line.done {
    background-color: #10b981;
  }

  /* Subtle entrance animation for the workspace whenever a new step
     renders — fade + slight upward slide. */
  #step-container {
    animation: l2-step-in 280ms cubic-bezier(.2,.7,.2,1);
  }
  @keyframes l2-step-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ============================================================
     Page backdrop — mint gradient + faded ligand silhouettes
     (same skin as the question modal so the whole game feels
     coherent). The HUD and step container float on top.
     ============================================================ */
  .l2-main {
    background:
      radial-gradient(circle at 18% 18%, #a7f3d0 0%, transparent 55%),
      radial-gradient(circle at 82% 82%, #5eead4 0%, transparent 55%),
      linear-gradient(135deg, #6ee7b7 0%, #34d399 50%, #10b981 100%);
  }
  .l2-main::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='720' height='720' viewBox='0 0 720 720'><g fill='%23ffffff' fill-opacity='0.08' font-family='Fredoka, system-ui, sans-serif' font-weight='700'><text x='40' y='80' font-size='40' transform='rotate(-12 40 80)'>NH%E2%82%83</text><text x='200' y='160' font-size='34' transform='rotate(8 200 160)'>H%E2%82%82O</text><text x='400' y='90' font-size='46' transform='rotate(-5 400 90)'>Cl%E2%81%BB</text><text x='560' y='200' font-size='36' transform='rotate(15 560 200)'>en</text><text x='80' y='320' font-size='38' transform='rotate(20 80 320)'>CN%E2%81%BB</text><text x='260' y='360' font-size='44' transform='rotate(-10 260 360)'>ox</text><text x='480' y='340' font-size='34' transform='rotate(6 480 340)'>py</text><text x='620' y='430' font-size='40' transform='rotate(-18 620 430)'>NH%E2%82%83</text><text x='120' y='510' font-size='34' transform='rotate(10 120 510)'>PPh%E2%82%83</text><text x='320' y='540' font-size='48' transform='rotate(-8 320 540)'>H%E2%82%82O</text><text x='540' y='600' font-size='38' transform='rotate(14 540 600)'>en</text><text x='40' y='640' font-size='32' transform='rotate(-22 40 640)'>acac</text><text x='400' y='240' font-size='30' transform='rotate(25 400 240)'>bipy</text></g></svg>");
    background-repeat: repeat;
    background-size: 720px 720px;
    opacity: 0.85;
    pointer-events: none;
    z-index: 0;
  }
  .l2-main > * {
    position: relative;
    z-index: 1;
  }

  /* ============================================================
     Kahoot-style L2 components — Hazim spec: "kahoot style smuanyaa
     untuk level 2 sahaja". Apply across step content rendered by
     level-2-game.js.
     ============================================================ */

  /* Step heading banner — big rounded blue gradient with Fredoka title. */
  .l2-step-banner {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 50%, #1e40af 100%);
    color: #fff;
    border-radius: 22px;
    padding: 16px 22px;
    margin: 0 0 16px;
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.25), inset 0 -4px 0 rgba(0,0,0,0.18);
    position: relative;
    overflow: hidden;
  }
  .l2-step-banner h2 {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: 1.2;
    margin: 0 0 4px;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.18);
  }
  .l2-step-banner p {
    color: rgba(255,255,255,0.92);
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.4;
  }
  .l2-step-banner .l2-step-pts {
    font-weight: 600;
    color: #fde68a;
    background: rgba(0,0,0,0.18);
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    margin-left: 8px;
    display: inline-block;
  }

  /* Kahoot 2-2 vibrant button with bouncy depth shadow. */
  .l2-kahoot-btn {
    --bg:  #3b82f6;
    --bgd: #1d4ed8;
    background: var(--bg);
    color: #fff;
    border-radius: 18px;
    padding: 18px 16px;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    text-align: center;
    box-shadow: 0 6px 0 var(--bgd), 0 10px 18px rgba(0,0,0,0.18);
    border: none;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s, opacity 0.15s;
    line-height: 1.2;
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 4px;
  }
  .l2-kahoot-btn:hover  { transform: translateY(2px); box-shadow: 0 4px 0 var(--bgd), 0 8px 14px rgba(0,0,0,0.18); }
  .l2-kahoot-btn:active { transform: translateY(5px); box-shadow: 0 1px 0 var(--bgd), 0 3px 6px rgba(0,0,0,0.18); }
  .l2-kahoot-btn:disabled { cursor: default; }

  .l2-kahoot-btn--red    { --bg: #ef4444; --bgd: #991b1b; }
  .l2-kahoot-btn--yellow { --bg: #f59e0b; --bgd: #b45309; }
  .l2-kahoot-btn--green  { --bg: #22c55e; --bgd: #15803d; }
  .l2-kahoot-btn--purple { --bg: #8b5cf6; --bgd: #5b21b6; }
  .l2-kahoot-btn--teal   { --bg: #14b8a6; --bgd: #0f766e; }
  .l2-kahoot-btn--pink   { --bg: #ec4899; --bgd: #9d174d; }

  .l2-kahoot-btn[data-state="selected"] {
    --bg: #f59e0b; --bgd: #b45309;
    transform: translateY(2px) scale(1.01);
  }
  .l2-kahoot-btn[data-state="correct"] { --bg: #22c55e; --bgd: #15803d; }
  .l2-kahoot-btn[data-state="wrong"]   { --bg: #ef4444; --bgd: #991b1b; animation: l2-kahoot-shake 0.4s; }
  .l2-kahoot-btn[data-state="faded"]   { opacity: 0.4; pointer-events: none; }
  .l2-kahoot-btn[data-state="eliminated"] {
    --bg: #cbd5e1; --bgd: #94a3b8;
    color: #475569;
    text-decoration: line-through;
    cursor: not-allowed;
    pointer-events: none;
    box-shadow: 0 3px 0 var(--bgd);
  }

  .l2-kahoot-btn .l2-btn-sub {
    font-size: 0.7em;
    font-weight: 500;
    opacity: 0.85;
  }

  @keyframes l2-kahoot-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  /* Nav buttons (Submit / Back / Next). */
  .l2-nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 18px;
    gap: 12px;
  }
  .l2-nav-btn {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    padding: 12px 26px;
    border-radius: 16px;
    transition: transform 0.15s, box-shadow 0.15s;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .l2-nav-btn--primary {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
    box-shadow: 0 5px 0 #1e3a8a, 0 8px 14px rgba(0,0,0,0.18);
  }
