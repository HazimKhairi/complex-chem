---
import { cn } from "../../lib/utils";
---

<table
  class={cn(
    "path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:relative",
    "[&_td]:w-[36px] [&_td]:h-[36px] [&_td]:sm:w-[38px] [&_td]:sm:h-[38px] [&_td]:md:w-[40px] [&_td]:md:h-[40px] [&_td]:lg:w-[42px] [&_td]:lg:h-[42px]",
    "[&_img]:w-[14px] [&_img]:sm:w-[15px] [&_img]:md:w-4 [&_img]:lg:w-[18px]",
    "[&_img]:mx-auto [&_img]:relative [&_img]:z-20 [&_img]:drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]",
    "border-collapse m-0 p-0",
  )}
>
  <!-- TOP ARM — between top-left and top-right home corners.
       Per latest spec (image #25), per-cell ligand layout:
         Row 1: O²⁻ | y52 | START (yellow's start, kept)
         Row 2: complex | y53 | CN⁻
         Row 3: en | y54 | complex
         Row 4: ox | y55 | Cl
         Row 5: ⚠ (fate) | y56 | PPh₃
       The middle column is yellow's winning stretch (y52-y56), unlabelled.
  -->
  <tr>
    <td class="g10 y49 r23 b36"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >O²⁻</span
      ></td
    >
    <td class="y52 " style="background-color:#f4e4a4"></td>
    <td class="g14 y1 r27 b40 start-tile start-tile-yellow"
      ><span
        class="start-label text-[8px] sm:text-[9px] font-black text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none tracking-tighter"
        >START</span
      ></td
    >
  </tr>
  <tr>
    <td
      class="g9 y48 r22 b35"
      style="background: #3b82f6 url('/complexes/3.png') center/cover no-repeat !important;"
    ></td>
    <td class="y53 " style="background-color:#f4e4a4"></td>
    <td class="g15 y2 r28 b41"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >CN⁻</span
      ></td
    >
  </tr>
  <tr>
    <td class="g8 y47 r21 b34"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >en</span
      ></td
    >
    <td class="y54 " style="background-color:#f4e4a4"></td>
    <td
      class="g16 y3 r29 b42"
      style="background: #3b82f6 url('/complexes/4.png') center/cover no-repeat !important;"
    ></td>
  </tr>
  <tr>
    <td class="g7 y46 r20 b33"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >ox</span
      ></td
    >
    <td class="y55 " style="background-color:#f4e4a4"></td>
    <td class="g17 y4 r30 b43"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >Cl</span
      ></td
    >
  </tr>
  <tr>
    <td
      class="g6 y45 r19 b32"
      style="background: #3b82f6 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td class="y56 " style="background-color:#f4e4a4"></td>
    <td class="g18 y5 r31 b44"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >PPh₃</span
      ></td
    >
  </tr>
</table>
