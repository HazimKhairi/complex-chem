---
interface Props {
  countdownFrom?: number;
}

const { countdownFrom = 3 } = Astro.props;
---

<div id="game-start-countdown" class="fixed inset-0 flex items-center justify-center bg-black/80 z-50" style="animation: fadeOutAndRemove 3s forwards;">
  <div class="bg-white rounded-lg p-5 text-center shadow-lg" style="animation: countdownPulse 3s ease-in-out;">
    <p id="countdown-text" class="text-6xl font-bold text-ludon-blue" style="animation: numberChange 3s steps(3);">3</p>
    <p class="text-sm mt-2 text-gray-700">Get ready to play!</p>
    <div class="mt-3 flex justify-center space-x-1">
      <span class="w-2 h-2 bg-ludon-red rounded-full animate-pulse"></span>
      <span class="w-2 h-2 bg-ludon-blue rounded-full animate-pulse animation-delay-300"></span>
      <span class="w-2 h-2 bg-ludon-green rounded-full animate-pulse animation-delay-600"></span>
      <span class="w-2 h-2 bg-ludon-yellow rounded-full animate-pulse animation-delay-900"></span>
    </div>
  </div>
</div>

<style>
  @keyframes fadeOutAndRemove {
    0%, 90% {
      opacity: 1;
      visibility: visible;
    }
    100% {
      opacity: 0;
      visibility: hidden;
      display: none;
      pointer-events: none;
    }
  }

  @keyframes countdownPulse {
    0%, 33% {
      transform: scale(1);
    }
    16.5% {
      transform: scale(1.1);
    }
    33%, 66% {
      transform: scale(1);
    }
    49.5% {
      transform: scale(1.1);
    }
    66%, 100% {
      transform: scale(1);
    }
    82.5% {
      transform: scale(1.1);
    }
  }
</style>

<script is:inline>
  console.log('🎮 [COUNTDOWN] ========== SCRIPT STARTED ==========');
  console.log('🎮 [COUNTDOWN] Current time:', new Date().toLocaleTimeString());
  console.log('🎮 [COUNTDOWN] Document ready state:', document.readyState);

  // Check if element exists immediately
  const countdownCheck = document.getElementById("game-start-countdown");
  console.log('🎮 [COUNTDOWN] Element exists on script load:', !!countdownCheck);
  if (countdownCheck) {
    console.log('🎮 [COUNTDOWN] Element styles:', window.getComputedStyle(countdownCheck).animation);
  }

  // Pure CSS animation handles countdown (3 seconds)
  // This script just removes the element from DOM after animation completes
  console.log('🎮 [COUNTDOWN] Setting timeout for 3100ms to remove element...');

  const removalTimeout = setTimeout(() => {
    console.log('🎮 [COUNTDOWN] ⏰ TIMEOUT FIRED! Time:', new Date().toLocaleTimeString());
    const countdown = document.getElementById("game-start-countdown");
    console.log('🎮 [COUNTDOWN] Element still exists:', !!countdown);

    if (countdown) {
      console.log('🎮 [COUNTDOWN] Removing element from DOM...');
      countdown.remove();
      console.log('✅ [COUNTDOWN] Element removed successfully!');
    } else {
      console.log('⚠️ [COUNTDOWN] Element already gone (maybe removed elsewhere?)');
    }

    console.log('🎮 [COUNTDOWN] ========== SCRIPT COMPLETE ==========');
  }, 3100); // 3 seconds animation + 100ms buffer

  console.log('🎮 [COUNTDOWN] Timeout ID:', removalTimeout);
  console.log('🎮 [COUNTDOWN] Waiting for 3100ms...');
</script>
