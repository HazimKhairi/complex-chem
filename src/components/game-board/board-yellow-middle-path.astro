---
import { cn } from "../../lib/utils";
---

<table
  class={cn(
    "path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:relative",
    "[&_td]:w-[36px] [&_td]:h-[36px] [&_td]:sm:w-[38px] [&_td]:sm:h-[38px] [&_td]:md:w-[40px] [&_td]:md:h-[40px] [&_td]:lg:w-[42px] [&_td]:lg:h-[42px]",
    "[&_img]:w-[22px] [&_img]:sm:w-[24px] [&_img]:md:w-[26px] [&_img]:lg:w-[28px]",
    "[&_img]:mx-auto [&_img]:relative [&_img]:z-20 [&_img]:drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]",
    "border-collapse m-0 p-0",
  )}
>
  <!-- BOTTOM ARM — between bottom-left (red) and bottom-right (blue) home corners.
       Per latest spec (image #27), per-cell layout (top of arm = closer
       to centre; bottom of arm = closer to bottom edge):
         Row 1: PPh₃        | r56 | ⚠ (fate)
         Row 2: Cl          | r55 | ox
         Row 3: complex     | r54 | en
         Row 4: CN⁻         | r53 | complex
         Row 5: START (r)   | r52 | O²⁻
  -->
  <tr>
    <td class="g44 y31 r5 b18"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >PPh₃</span
      ></td
    >
    <td class="r56 " style="background-color:#f48c94"></td>
    <td
      class="g32 y19 r45 b6"
      style="background: #eab308 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
  </tr>
  <tr>
    <td class="g43 y30 r4 b17"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >Cl</span
      ></td
    >
    <td class="r55 " style="background-color:#f48c94"></td>
    <td class="g33 y20 r46 b7"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >ox</span
      ></td
    >
  </tr>
  <tr>
    <td
      class="g42 y29 r3 b16"
      style="background: #eab308 url('/complexes/5.png') center/cover no-repeat !important;"
    ></td>
    <td class="r54 " style="background-color:#f48c94"></td>
    <td class="g34 y21 r47 b8"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >en</span
      ></td
    >
  </tr>
  <tr>
    <td class="g41 y28 r2 b15"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >CN⁻</span
      ></td
    >
    <td class="r53 " style="background-color:#f48c94"></td>
    <td
      class="g35 y22 r48 b9"
      style="background: #eab308 url('/complexes/6.png') center/cover no-repeat !important;"
    ></td>
  </tr>
  <tr>
    <td class="g40 y27 r1 b14 start-tile start-tile-red"
      ><span
        class="start-label text-[8px] sm:text-[9px] font-black text-gray-900 flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none tracking-tighter"
        >START</span
      ></td
    >
    <td class="r52 " style="background-color:#f48c94"></td>
    <td class="g36 y23 r49 b10"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >O²⁻</span
      ></td
    >
  </tr>
</table>
