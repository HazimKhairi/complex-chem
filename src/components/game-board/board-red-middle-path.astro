---
import { cn } from "../../lib/utils";
---

<table
  class={cn(
    "middle-table path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:relative",
    "[&_td]:w-[36px] [&_td]:h-[36px] [&_td]:sm:w-[38px] [&_td]:sm:h-[38px] [&_td]:md:w-[40px] [&_td]:md:h-[40px] [&_td]:lg:w-[42px] [&_td]:lg:h-[42px]",
    "[&_img]:w-[22px] [&_img]:sm:w-[24px] [&_img]:md:w-[26px] [&_img]:lg:w-[28px]",
    "[&_img]:mx-auto [&_img]:relative [&_img]:z-20 [&_img]:drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]",
    "border-collapse m-0 p-0",
  )}
>
  <tr>
    <td class="r1 b40 y14 g27 start-tile start-tile-red"
      ><span
        class="start-label text-[8px] sm:text-[9px] font-black text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none tracking-tighter"
        >START</span
      ></td
    >
    <td class="r2 b41 y15 g28"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >H₂O</span
      ></td
    >
    <td
      class="r3 b42 y16 g29"
      style="background: #ef4444 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td
      class="r4 b43 y17 g30"
      style="background: #ef4444 url('/complexes/7.png') center/cover no-repeat !important;"
    ></td>
    <td class="r5 b44 y18 g31"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >phen</span
      ></td
    >
  </tr>
  <tr class="middle-row-red">
    <!-- <td class="r51 b38 y12 g25 bg-[url('/arrows/red.png')] bg-contain"></td> -->
    <td class="r52 bg-red-300"></td>
    <td class="r53 bg-red-300"></td>
    <td class="r54 bg-red-300"></td>
    <td class="r55 bg-red-300"></td>
    <td class="r56 bg-red-300"></td>
  </tr>
  <tr>
    <td class="r50 b37 y11 g24"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >NH₃</span
      ></td
    >
    <td class="r49 b36 y10 g23"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >acac</span
      ></td
    >
    <td
      class="r48 b35 y9 g22"
      style="background: #ef4444 url('/complexes/8.png') center/cover no-repeat !important;"
    ></td>
    <td
      class="r47 b34 y8 g21"
      style="background: #ef4444 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td class="r46 b33 y7 g20"
      ><span
        class="text-[10px] text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none"
        >O²⁻</span
      ></td
    >
  </tr>
</table>
