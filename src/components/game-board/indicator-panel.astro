---
/*
 * Chemistry "Indicator" reference card for Level 2.
 * Small floating button, bottom-right. Opens a modal showing the
 * canonical ligand table (charge, colour sphere, denticity) and the
 * central-metal table. Data is rendered client-side from the same
 * LIGAND_CHEMISTRY object level-2-game.js uses, so the table is
 * always in sync with the game data.
 */
---

<button
  id="indicator-toggle"
  type="button"
  aria-label="Open indicator reference"
  class="fixed bottom-4 right-4 z-40 bg-ludon-blue hover:bg-blue-700 text-white rounded-full shadow-lg px-5 py-3 flex items-center gap-2 text-sm font-bold"
>
  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
    <circle cx="12" cy="12" r="9" />
    <path d="M12 8v4m0 4h.01" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  Indicator
</button>

<div
  id="indicator-modal"
  class="fixed inset-0 z-50 hidden bg-black/70 backdrop-blur-sm p-4 items-center justify-center"
>
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[92vh] overflow-hidden flex flex-col">
    <div class="bg-ludon-blue text-white px-5 py-3 flex items-center justify-between">
      <h2 class="text-lg font-bold tracking-wide uppercase">Indicator</h2>
      <button id="indicator-close" aria-label="Close" class="text-white/90 hover:text-white text-2xl leading-none">&times;</button>
    </div>

    <div class="flex-1 overflow-auto p-4 sm:p-5 grid grid-cols-1 lg:grid-cols-[3fr_1fr] gap-4">
      <!-- Ligand indicator table -->
      <div class="rounded-xl border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-ludon-blue text-white">
            <tr>
              <th class="text-left px-3 py-2 font-semibold">Ligand</th>
              <th class="px-3 py-2 font-semibold">Charge</th>
              <th class="px-3 py-2 font-semibold">Colour sphere</th>
              <th class="px-3 py-2 font-semibold">Shape sphere bond</th>
              <th class="px-3 py-2 font-semibold">Type of denticity</th>
            </tr>
          </thead>
          <tbody id="indicator-ligand-tbody"></tbody>
        </table>
      </div>

      <!-- Central metal table -->
      <div class="rounded-xl border border-gray-200 overflow-hidden h-fit">
        <table class="w-full text-sm">
          <thead class="bg-ludon-blue text-white">
            <tr>
              <th class="text-left px-3 py-2 font-semibold">Central metal</th>
              <th class="px-3 py-2 font-semibold">Charge</th>
            </tr>
          </thead>
          <tbody id="indicator-metal-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  type Ligand = { id: string; name: string; charge: number; denticity: number; type: string; sphere: string; };
  type Metal = { name: string; id: string; charge: number; };

  // Mirror of level-2-game.js data. Kept in sync manually; keep these
  // two in lock-step when adding a ligand.
  const LIGANDS: Ligand[] = [
    { id: "h2o",  name: "H₂O",    charge: 0,  denticity: 1, type: "Monodentate", sphere: "red" },
    { id: "nh3",  name: "NH₃",    charge: 0,  denticity: 1, type: "Monodentate", sphere: "blue" },
    { id: "py",   name: "py",     charge: 0,  denticity: 1, type: "Monodentate", sphere: "blue" },
    { id: "pph3", name: "PPh₃",   charge: 0,  denticity: 1, type: "Monodentate", sphere: "orange" },
    { id: "cn",   name: "CN⁻",    charge: -1, denticity: 1, type: "Monodentate", sphere: "blue" },
    { id: "o2",   name: "O²⁻",    charge: -2, denticity: 1, type: "Monodentate", sphere: "red" },
    { id: "cl",   name: "Cl⁻",    charge: -1, denticity: 1, type: "Monodentate", sphere: "green" },
    { id: "ox",   name: "Ox²⁻",   charge: -2, denticity: 2, type: "Bidentate",   sphere: "red" },
    { id: "acac", name: "acac⁻",  charge: -1, denticity: 2, type: "Bidentate",   sphere: "red" },
    { id: "co32", name: "CO₃²⁻",  charge: -2, denticity: 2, type: "Bidentate",   sphere: "red" },
    { id: "phen", name: "phen",   charge: 0,  denticity: 2, type: "Bidentate",   sphere: "blue" },
    { id: "bipy", name: "bipy",   charge: 0,  denticity: 2, type: "Bidentate",   sphere: "blue" },
    { id: "en",   name: "en",     charge: 0,  denticity: 2, type: "Bidentate",   sphere: "blue" },
  ];

  const METALS: Metal[] = [
    { id: "co3", name: "Co³⁺", charge: 3 },
    { id: "cr3", name: "Cr³⁺", charge: 3 },
    { id: "fe3", name: "Fe³⁺", charge: 3 },
    { id: "cu2", name: "Cu²⁺", charge: 2 },
    { id: "ni2", name: "Ni²⁺", charge: 2 },
    { id: "zn2", name: "Zn²⁺", charge: 2 },
  ];

  const SPHERE_CSS: Record<string, string> = {
    red:    "#EF4444",
    blue:   "#3B82F6",
    orange: "#F97316",
    green:  "#10B981",
  };

  function renderBondShape(denticity: number, color: string): string {
    // Monodentate = single dot; Bidentate = two dots linked by an arc
    const c = SPHERE_CSS[color] || "#6B7280";
    if (denticity === 1) {
      return `<span class="inline-block w-3 h-3 rounded-full align-middle" style="background:${c}"></span>`;
    }
    return `
      <span class="inline-flex items-center gap-0 align-middle">
        <span class="inline-block w-3 h-3 rounded-full" style="background:${c}"></span>
        <span class="inline-block w-4 h-3 border-t-2 border-b-0 border-r-0 border-l-0" style="border-top: 3px solid ${c}; border-radius: 999px 999px 0 0; margin: 0 1px;"></span>
        <span class="inline-block w-3 h-3 rounded-full" style="background:${c}"></span>
      </span>
    `;
  }

  function renderLigandRows() {
    const tbody = document.getElementById("indicator-ligand-tbody");
    if (!tbody) return;
    tbody.innerHTML = LIGANDS.map((l) => {
      const colourCell = `<span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded-full" style="background:${SPHERE_CSS[l.sphere]}"></span>${l.sphere.charAt(0).toUpperCase() + l.sphere.slice(1)}</span>`;
      return `
        <tr class="border-t border-gray-100">
          <td class="px-3 py-2 font-medium">${l.name}</td>
          <td class="text-center px-3 py-2">${l.charge > 0 ? "+" + l.charge : l.charge}</td>
          <td class="px-3 py-2">${colourCell}</td>
          <td class="px-3 py-2 text-center">${renderBondShape(l.denticity, l.sphere)}</td>
          <td class="px-3 py-2">${l.type}</td>
        </tr>`;
    }).join("");
  }

  function renderMetalRows() {
    const tbody = document.getElementById("indicator-metal-tbody");
    if (!tbody) return;
    tbody.innerHTML = METALS.map((m) => `
      <tr class="border-t border-gray-100">
        <td class="px-3 py-2 font-medium">${m.name}</td>
        <td class="text-center px-3 py-2 font-semibold">+${m.charge}</td>
      </tr>`).join("");
  }

  renderLigandRows();
  renderMetalRows();

  const modal = document.getElementById("indicator-modal")!;
  const toggle = document.getElementById("indicator-toggle")!;
  const closeBtn = document.getElementById("indicator-close")!;

  function open() {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }
  function close() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  toggle.addEventListener("click", open);
  closeBtn.addEventListener("click", close);
  modal.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
  });
</script>
