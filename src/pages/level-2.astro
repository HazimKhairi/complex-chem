---
import Layout from "../layouts/Layout.astro";
import GameSettingsMenu from "../components/game-settings-menu.astro";
import Level2IntroModal from "../components/game-board/level2-intro-modal.astro";
import IndicatorPanel from "../components/game-board/indicator-panel.astro";
import LoadingScreen from "../components/loading-screen.astro";
import LevelTwoPodium from "../components/game-board/level2-podium.astro";
---

<Layout>
  <LoadingScreen />
  <LevelTwoPodium />
  <GameSettingsMenu />
  <Level2IntroModal />
  <IndicatorPanel />
  <main class="l2-stage h-dvh px-3 py-2 flex flex-col items-center gap-2 overflow-hidden">
    <!-- TOP HUD — gradient game bar with brand, step indicator, score chip -->
    <div class="w-full max-w-6xl rounded-2xl shadow-lg overflow-hidden flex-shrink-0 bg-gradient-to-r from-[#1e3a8a] via-[#2563eb] to-[#1e40af]">
      <div class="flex items-center justify-between gap-3 px-4 py-2">
        <!-- Brand cluster + Kahoot-mock utility icons -->
        <div class="flex items-center gap-2 min-w-0">
          <div class="w-9 h-9 rounded-xl bg-amber-400 flex items-center justify-center font-black text-blue-900 text-base shadow-md">
            L2
          </div>
          <div class="min-w-0">
            <p class="text-white font-black text-sm sm:text-base leading-tight truncate" style="font-family: 'Fredoka', sans-serif;">
              Build Your Complex
            </p>
            <p id="player-info" class="text-blue-100 text-[10px] truncate"></p>
          </div>
          <!-- Top-left utility icons (mute, music, restart, info). -->
          <span class="l2-util-icons hidden sm:inline-flex">
            <button id="l2-util-mute" type="button" class="l2-util-icon" title="Mute / unmute SFX">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M19 12c0-1.66-.93-3.1-2.3-3.83"/><path d="M22 12c0-3.31-2-6.18-4.85-7.41"/></svg>
            </button>
            <button id="l2-util-music" type="button" class="l2-util-icon" title="Music">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            </button>
            <button id="l2-util-restart" type="button" class="l2-util-icon" title="Restart Level 2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
            </button>
            <button id="l2-util-info" type="button" class="l2-util-icon" title="How to play">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </button>
          </span>
        </div>

        <!-- Step Indicator (5 stages) -->
        <div class="hidden sm:flex items-center justify-center gap-0 flex-1 max-w-md">
          {[1, 2, 3, 4, 5].map((n, i) => (
            <>
              <div
                class="step-dot flex items-center justify-center rounded-full text-white font-bold text-xs shrink-0"
                data-step={n}
              >
                {n}
              </div>
              {i < 4 && <div class="step-line flex-1" />}
            </>
          ))}
        </div>

        <!-- Score chip — gold leaderboard vibe, BIG numerals so the
             score is the loudest thing on the HUD bar. -->
        <div class="flex items-center gap-2 px-4 py-2 rounded-2xl bg-gradient-to-r from-amber-400 to-yellow-500 shadow-lg ring-2 ring-amber-200">
          <svg class="w-5 h-5 text-amber-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.39 7.36H22l-6.19 4.5L18.2 21 12 16.27 5.8 21l2.39-7.14L2 9.36h7.61z"/>
          </svg>
          <span class="text-[10px] font-black text-amber-900 uppercase tracking-wider hidden sm:inline">Score</span>
          <span id="hud-total-score" class="text-2xl sm:text-3xl font-black text-blue-900 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
        </div>
      </div>

      <!-- Step Indicator (mobile fallback row) -->
      <div class="sm:hidden flex items-center justify-center gap-0 px-4 pb-2 max-w-md mx-auto">
        {[1, 2, 3, 4, 5].map((n, i) => (
          <>
            <div
              class="step-dot flex items-center justify-center rounded-full text-white font-bold text-xs shrink-0"
              data-step={n}
            >
              {n}
            </div>
            {i < 4 && <div class="step-line flex-1" />}
          </>
        ))}
      </div>
    </div>

    <!-- Collected ligands HUD rail -->
    <div
      id="collected-ligands-strip"
      class="w-full max-w-6xl bg-white rounded-2xl shadow-md border-2 border-blue-100 px-3 py-2 hidden flex-shrink-0"
    >
      <div class="flex items-center gap-2 overflow-x-auto">
        <span class="text-[10px] font-black uppercase tracking-wider text-blue-700 flex-shrink-0">Inventory</span>
        <span class="text-[10px] text-gray-400 flex-shrink-0">·</span>
        <span class="text-[10px] text-gray-500 flex-shrink-0"><span id="cl-count">0</span> ligand(s)</span>
        <span class="text-[10px] text-gray-300 flex-shrink-0">|</span>
        <div id="collected-ligands-list" class="flex flex-nowrap gap-1.5 overflow-x-auto"></div>
      </div>
    </div>

    <!-- Two-column workspace: step content (left) + 3D builder (right
         when visible). When the builder is hidden the step container
         expands to use the full width. -->
    <div id="l2-workspace" class="w-full max-w-6xl flex-1 min-h-0 grid grid-cols-1 gap-3 lg:grid-cols-1" data-builder-visible="false">
      <!-- Step Content Container — hugs its own content height
           (self-start) so a short message like "Try again" doesn't
           leave a giant empty white card. Caps at the available
           viewport height, scrolls internally if content is taller. -->
      <div
        id="step-container"
        class="l2-stage-card rounded-2xl shadow-xl p-4 sm:p-5 self-start w-full max-h-full overflow-y-auto"
      >
        <p class="text-gray-400 text-center mt-20">Loading...</p>
      </div>

      <!-- 3D Canvas (hidden until Step 5). max-h-full + min-h-0 keep
           the whole card capped to its grid cell so the score bar
           never gets pushed below the viewport. -->
      <div id="builder-container" class="hidden min-h-0 max-h-full flex flex-col">
        <div class="bg-white rounded-2xl shadow-md overflow-hidden flex-1 flex flex-col min-h-0 max-h-full relative ring-4 ring-blue-200">
          <!-- Outer-complex header bar — sits OUTSIDE the 3D scene.
               Hazim spec 2026-05-10 "tkde kotak mcm sy minta tu luar
               complex" — make the outer formula box visually distinct
               from the canvas with a thicker border, deeper shadow,
               and explicit "Your Complex" caption.
               "tk nampak sepenuhnya ligand" — formula no longer
               truncates: it wraps onto multiple lines and auto-shrinks
               on long inputs so every (ligand)ₙ stays readable. -->
          <!-- Hazim 2026-05-11: removed the standalone CHARGE pill —
               it was clipping the formula's right edge ("]⁺" was
               disappearing behind it on long inputs). The formula
               itself already encodes the charge at the bracket close
               (e.g. "[Co(H₂O)(ox)(bipy)]⁺") so the pill was
               redundant. Formula box now spans the full row width
               with a fixed font size that wraps to a second line
               when the chemistry gets long, instead of shrinking the
               text. -->
          <div id="builder-outer-box" class="px-3 py-2 border-b-2 border-blue-300 bg-gradient-to-r from-sky-50 via-white to-blue-50 flex-shrink-0">
            <span class="block text-[11px] font-black uppercase tracking-widest text-blue-600 mb-1">Build this</span>
            <div class="l2-formula-box w-full">
              <div id="builder-formula" class="l2-formula px-3 py-2 rounded-xl bg-white shadow border-2 border-blue-400 text-blue-900 font-extrabold tabular-nums tracking-wide leading-tight"
                   style="font-family:'Fredoka',system-ui,sans-serif;">
                <span class="text-gray-400 text-base">[ build your complex ]</span>
              </div>
            </div>
          </div>
          <!-- Hazim 2026-05-11: wrap the 3D scene in BIG chemistry
               brackets with the complex charge as a superscript at
               the top-right, mimicking the formula notation
               "[Co(NH₃)₃(H₂O)₃]³⁺" but rendered around the actual
               3D model. Brackets drawn via CSS pseudo-elements on
               #l2-bracket-frame so they overlay the canvas without
               blocking pointer events. -->
          <div id="l2-bracket-frame" class="relative flex-1 min-h-0">
            <canvas id="three-canvas" class="w-full h-full" style="touch-action:none;"></canvas>
            <span id="l2-bracket-charge" class="hidden"></span>
          </div>
          <!-- Currently-armed ligand pill — gives visual feedback for
               which ligand the player is about to place (Hazim spec:
               "tk nampak player pilih mana"). -->
          <div id="builder-armed-row" class="px-3 py-1.5 border-t border-gray-100 flex items-center gap-2 flex-shrink-0 hidden">
            <span class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Picked up:</span>
            <span id="builder-armed-pill" class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 border-2 border-amber-400 shadow-sm">
              <span id="builder-armed-dot" class="w-4 h-4 rounded-full" style="background:#9ca3af;"></span>
              <span id="builder-armed-name" class="text-xs font-bold text-amber-900">—</span>
            </span>
          </div>
          <div class="px-3 py-1.5 border-t border-gray-100 flex-shrink-0">
            <p class="text-[11px] text-amber-700 font-black uppercase tracking-wide mb-1">Your Ligands — <span class="text-blue-700">TAP to pick up</span>, then <span class="text-blue-700">DRAG</span> onto empty slots</p>
            <div id="ligand-inventory" class="flex flex-wrap gap-1.5 justify-center min-h-[36px]"></div>
          </div>
          <div class="px-3 py-1.5 border-t border-gray-100 flex justify-between items-center flex-shrink-0">
            <div class="text-xs text-gray-600">Slots filled: <strong id="slots-filled">0</strong> / <strong id="slots-total">0</strong></div>
            <div class="flex gap-2">
              <button id="btn-reset-3d" class="px-3 py-1.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 text-xs font-semibold">Reset</button>
              <button id="btn-submit-3d" class="px-3 py-1.5 rounded-lg bg-[#4187a0] text-white font-semibold text-xs hover:bg-[#357a91] disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed" disabled>Submit</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Score Bar — three pill badges with BIG Fredoka numerals.
         "Score tu nak besar" — Hazim spec. -->
    <div class="w-full max-w-6xl flex gap-2 sm:gap-3 flex-shrink-0">
      <div class="flex-1 bg-white border-2 border-blue-200 rounded-2xl px-3 py-2 flex items-center justify-between shadow-md">
        <span class="text-[10px] sm:text-xs font-black text-blue-700 uppercase tracking-widest">Level 1</span>
        <span id="l1-score" class="text-xl sm:text-3xl font-black text-blue-700 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
      <div class="flex-1 bg-white border-2 border-emerald-200 rounded-2xl px-3 py-2 flex items-center justify-between shadow-md">
        <span class="text-[10px] sm:text-xs font-black text-emerald-700 uppercase tracking-widest">Level 2</span>
        <span id="l2-score" class="text-xl sm:text-3xl font-black text-emerald-700 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
      <div class="flex-[1.2] bg-gradient-to-r from-amber-400 to-orange-500 rounded-2xl px-3 py-2 flex items-center justify-between shadow-lg ring-2 ring-amber-200">
        <span class="text-[10px] sm:text-xs font-black text-orange-900 uppercase tracking-widest">Total</span>
        <span id="total-score" class="text-2xl sm:text-4xl font-black text-blue-900 tabular-nums leading-none" style="font-family:'Fredoka',system-ui,sans-serif;">0</span>
      </div>
    </div>
  </main>

  <!-- Mirror total-score updates into the HUD chip too -->
  <script is:inline>
    (function () {
      var src = document.getElementById('total-score');
      var dst = document.getElementById('hud-total-score');
      if (!src || !dst) return;
      var obs = new MutationObserver(function () { dst.textContent = src.textContent; });
      obs.observe(src, { childList: true, characterData: true, subtree: true });
    })();
  </script>

  <!-- Wire the 4 Kahoot-mock utility icons. Mute toggles AudioManager
       SFX volume, Music toggles BGM, Restart wipes Level 2 state and
       reloads, Info re-shows the objective intro modal. -->
  <script is:inline>
    (function () {
      var muteBtn  = document.getElementById('l2-util-mute');
      var musicBtn = document.getElementById('l2-util-music');
      var restart  = document.getElementById('l2-util-restart');
      var infoBtn  = document.getElementById('l2-util-info');

      muteBtn && muteBtn.addEventListener('click', function () {
        var muted = localStorage.getItem('game-muted') === 'true';
        localStorage.setItem('game-muted', muted ? 'false' : 'true');
        muteBtn.style.opacity = muted ? '1' : '0.5';
      });
      // Reflect current state on first paint.
      if (muteBtn && localStorage.getItem('game-muted') === 'true') muteBtn.style.opacity = '0.5';

      musicBtn && musicBtn.addEventListener('click', function () {
        if (!window.AudioManager) return;
        if (window.__l2Music) {
          window.AudioManager.stopBGM && window.AudioManager.stopBGM();
          window.__l2Music = false;
          musicBtn.style.opacity = '0.5';
        } else {
          window.AudioManager.startBGM && window.AudioManager.startBGM();
          window.__l2Music = true;
          musicBtn.style.opacity = '1';
        }
      });

      restart && restart.addEventListener('click', function () {
        if (!confirm('Restart Level 2? Your current progress will be lost.')) return;
        sessionStorage.removeItem('level2-state');
        sessionStorage.removeItem('level2-intro-seen');
        window.location.reload();
      });

      infoBtn && infoBtn.addEventListener('click', function () {
        var modal = document.getElementById('level2-intro-modal');
        if (!modal) return;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });
    })();
  </script>

  <script is:inline>
    if (!sessionStorage.getItem("game-state")) {
      window.location.href = "/pass-and-play";
    }
  </script>
  <!-- three.js pinned to r147 — last release with classic
       examples/js/controls/OrbitControls.js. r0.160 dropped that
       folder which 404'd and broke the 3D builder. -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.147.0/examples/js/controls/OrbitControls.js"></script>
  <script is:inline src="/scripts/audio-manager.js"></script>
  <script is:inline src="/scripts/joyride.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="/scripts/level-2-3d-builder.js"></script>
  <script is:inline src="/scripts/level-2-game.js"></script>
  <script is:inline src="/scripts/auto-play.js"></script>
  <script>
    // Play Level 2 intro chime on first user interaction (autoplay policy safe)
    (function () {
      let played = false;
      function playOnce() {
        if (played) return;
        played = true;
        if (window.AudioManager) window.AudioManager.play("level-2-start");
        document.removeEventListener("click", playOnce);
        document.removeEventListener("keydown", playOnce);
      }
      document.addEventListener("click", playOnce, { once: false });
      document.addEventListener("keydown", playOnce, { once: false });
    })();
  </script>
</Layout>

<!-- Game-feel typeface for the L2 HUD heading -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&display=swap" />

<style is:global>
  /* is:global so the dynamic showPointsToast() element + the JS-injected
     step content can pick up these selectors. Scoped styles get a build-
     time hash that runtime-created elements never have. */

  /* Step indicator inside the dark HUD bar — small, glowing pills */
  .step-dot {
    width: 26px;
    height: 26px;
    background-color: rgba(255, 255, 255, 0.18);
    border: 2px solid rgba(255, 255, 255, 0.25);
    transition: background-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .step-dot.active {
    background-color: #fbbf24;
    color: #1e3a8a !important;
    border-color: #fde68a;
    transform: scale(1.18);
    box-shadow: 0 0 0 4px rgba(251, 191, 36, 0.25);
  }
  .step-dot.done {
    background-color: #10b981;
    border-color: #6ee7b7;
  }
  .step-line {
    height: 3px;
    background-color: rgba(255, 255, 255, 0.2);
    transition: background-color 0.3s;
    margin: 0 2px;
    border-radius: 2px;
  }
  .step-line.done {
    background-color: #10b981;
  }

  /* Subtle entrance animation for the workspace whenever a new step
     renders — fade + slight upward slide. */
  #step-container {
    animation: l2-step-in 280ms cubic-bezier(.2,.7,.2,1);
    /* Hazim 2026-05-11: previously `self-start` was letting the grid
       auto-shrink to its content's intrinsic width, leaving a big
       empty band on the right of the workspace. Force the container
       to fill its grid cell so Q4's 6-image picker grid stretches
       across the full 1152 px workspace. */
    justify-self: stretch;
    align-self: stretch;
    width: 100%;
  }
  @keyframes l2-step-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Step heading banner — big rounded blue gradient with Fredoka title. */
  .l2-step-banner {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 50%, #1e40af 100%);
    color: #fff;
    border-radius: 22px;
    padding: 16px 22px;
    margin: 0 0 16px;
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.25), inset 0 -4px 0 rgba(0,0,0,0.18);
    position: relative;
    overflow: hidden;
  }
  .l2-step-banner h2 {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.2;
    margin: 0 0 8px;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.32);
    letter-spacing: 0.01em;
  }
  /* Subtitle — wrapped in a dark inset strip so the white text reads
     even when the banner gradient is partially clipped. */
  .l2-step-banner p {
    color: #fff;
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    font-weight: 600;
    margin: 0;
    line-height: 1.45;
    background: rgba(0,0,0,0.28);
    padding: 8px 14px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.18);
    text-shadow: 0 1px 2px rgba(0,0,0,0.35);
    display: block;
  }
  .l2-step-banner p strong { color: #fde68a; }
  .l2-step-banner .l2-step-pts {
    font-weight: 800;
    color: #1f2937;
    background: linear-gradient(135deg, #fde68a, #f59e0b);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.8rem;
    margin-left: 8px;
    display: inline-block;
    box-shadow: 0 2px 6px rgba(0,0,0,0.18);
    text-shadow: none;
  }

  /* Game-feel "Tap to pick" pill — PAKAR 1 2026-06-15.
     Bold all-caps label, dashed gold ring, soft pulse so the cell
     reads as an interactive game element instead of a quiz blank. */
  .l2-tap-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.95rem;
    border-radius: 9999px;
    background: linear-gradient(180deg, #fffbeb, #fef3c7);
    border: 2px dashed #f59e0b;
    color: #92400e;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    letter-spacing: 0.04em;
    font-size: 0.8rem;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 2px 0 #fbbf24, 0 4px 12px rgba(245, 158, 11, 0.18);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    position: relative;
    user-select: none;
  }
  .l2-tap-pill:hover {
    transform: translateY(-1px);
    background: linear-gradient(180deg, #fef3c7, #fde68a);
    box-shadow: 0 3px 0 #f59e0b, 0 6px 16px rgba(245, 158, 11, 0.28);
  }
  .l2-tap-pill:active { transform: translateY(1px); box-shadow: 0 1px 0 #fbbf24; }
  .l2-tap-pulse {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background: #f59e0b;
    box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.55);
    animation: l2TapPulse 1.6s ease-out infinite;
  }
  .l2-tap-label { font-weight: 900; }
  .l2-tap-plus {
    font-weight: 900;
    font-size: 1rem;
    line-height: 1;
    margin-left: 0.1rem;
  }
  @keyframes l2TapPulse {
    0%   { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.55); }
    70%  { box-shadow: 0 0 0 10px rgba(245, 158, 11, 0); }
    100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
  }

  /* ─────────────────────────────────────────────────────────────
     PAKAR 1 round 4 (Hazim 2026-06-15) — kill the white-paper vibe.
     "putih so dia nampak macam paper quiz" — Level 2 now sits on a
     vibrant purple→blue→teal gradient with subtle dot pattern, and
     the step card is a tinted glass panel with a gold accent rim
     instead of a flat white sheet.
     ───────────────────────────────────────────────────────────── */
  .l2-stage {
    background:
      radial-gradient(circle at 20% 18%, rgba(251, 191, 36, 0.16) 0%, transparent 38%),
      radial-gradient(circle at 80% 84%, rgba(244, 114, 182, 0.18) 0%, transparent 42%),
      linear-gradient(135deg, #4c1d95 0%, #1d4ed8 45%, #0e7490 100%);
    position: relative;
  }
  .l2-stage::before {
    content: "";
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 22px 22px;
    pointer-events: none;
    opacity: 0.55;
  }
  .l2-stage > * { position: relative; }

  /* Step card — tinted glass instead of bare white. Light enough to
     keep table copy readable but coloured enough to break out of
     "exam paper" territory. */
  .l2-stage-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 243, 255, 0.92));
    border: 3px solid #fcd34d;
    box-shadow:
      0 0 0 4px rgba(76, 29, 149, 0.35),
      0 20px 40px -12px rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(6px);
  }

  /* Banded table rows — replace pale tints with saturated game colours
     so each working row reads as its own "lane". */
  .l2-stage-card tbody tr:nth-child(odd) > td  { background: rgba(165, 180, 252, 0.18); }
  .l2-stage-card tbody tr:nth-child(even) > td { background: rgba(252, 211, 77, 0.16); }
  .l2-stage-card tbody tr.bg-emerald-50 > td   { background: linear-gradient(90deg, #34d399, #10b981) !important; color: #064e3b !important; }
  .l2-stage-card tbody tr.bg-blue-50 > td      { background: linear-gradient(90deg, #60a5fa, #3b82f6) !important; color: #1e3a8a !important; }
  .l2-stage-card tbody tr.bg-amber-50 > td     { background: linear-gradient(90deg, #fbbf24, #f59e0b) !important; color: #78350f !important; }
  .l2-stage-card thead tr                       { background: linear-gradient(90deg, #1e3a8a, #4c1d95) !important; }
  .l2-stage-card thead th                       { color: #fde68a !important; text-transform: uppercase; letter-spacing: 0.04em; }

  /* ─────────────────────────────────────────────────────────────
     PAKAR 1 round 3 (Hazim 2026-06-15) — drag-tile reactor for Q2.
     Each table cell renders as either an empty pulsing slot or a
     placed tile. A bottom tray holds the tile pool for the armed
     slot. Sells the "game" feeling Hazim asked for ("taknak nampak
     macam quiz").
     ───────────────────────────────────────────────────────────── */
  .l2-tile-slot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    height: 38px;
    padding: 0 0.5rem;
    border-radius: 10px;
    border: 2px dashed #cbd5e1;
    background: #f8fafc;
    color: #94a3b8;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .l2-tile-slot--empty:hover {
    border-color: #f59e0b;
    background: #fffbeb;
    color: #b45309;
    transform: translateY(-1px);
  }
  .l2-tile-slot--armed {
    border-color: #f59e0b;
    background: linear-gradient(180deg, #fef3c7, #fde68a);
    color: #92400e;
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.18);
    animation: l2SlotPulse 1.2s ease-in-out infinite;
  }
  .l2-tile-slot--done { opacity: 0.45; cursor: default; }
  @keyframes l2SlotPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.45); }
    50%      { box-shadow: 0 0 0 8px rgba(245, 158, 11, 0.05); }
  }

  .l2-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    height: 38px;
    padding: 0 0.7rem;
    border-radius: 10px;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 900;
    font-size: 1rem;
    line-height: 1;
    border: 2px solid transparent;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    user-select: none;
  }
  .l2-tile--placed {
    background: linear-gradient(180deg, #3b82f6, #1d4ed8);
    color: #fff;
    border-color: #1e3a8a;
    box-shadow: 0 3px 0 #1e3a8a, 0 4px 12px rgba(29, 78, 216, 0.28);
    cursor: pointer;
    animation: l2TileDrop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) 1;
  }
  .l2-tile--placed:hover { transform: translateY(-1px); }
  .l2-tile--placed:active { transform: translateY(1px); box-shadow: 0 1px 0 #1e3a8a; }
  .l2-tile--correct {
    background: linear-gradient(180deg, #22c55e, #15803d);
    color: #fff; border-color: #14532d;
    box-shadow: 0 3px 0 #14532d, 0 4px 12px rgba(21, 128, 61, 0.28);
  }
  .l2-tile--wrong {
    background: linear-gradient(180deg, #ef4444, #b91c1c);
    color: #fff; border-color: #7f1d1d;
    box-shadow: 0 3px 0 #7f1d1d, 0 4px 12px rgba(185, 28, 28, 0.28);
  }
  @keyframes l2TileDrop {
    0%   { transform: scale(0.4) rotate(-8deg); opacity: 0; }
    60%  { transform: scale(1.15) rotate(2deg); opacity: 1; }
    100% { transform: scale(1)    rotate(0); }
  }

  /* Bottom tray — gradient panel, large tiles, scroll on overflow. */
  .l2-tile-tray {
    margin: 0.5rem 0 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 14px;
    background: linear-gradient(180deg, #0f172a, #1e293b);
    color: #fff;
    box-shadow: inset 0 2px 0 rgba(255,255,255,0.05), 0 6px 16px rgba(15, 23, 42, 0.25);
  }
  .l2-tile-tray-head {
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .l2-tile-tray-progress {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.12);
    border-radius: 999px;
    overflow: hidden;
  }
  .l2-tile-tray-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #f59e0b, #fbbf24);
    border-radius: 999px;
    transition: width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .l2-tile-tray-progress-label {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    color: #fbbf24;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .l2-tile-tray-label {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 800;
    color: #fde047;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }
  .l2-tile-tray-tiles {
    display: flex; flex-wrap: wrap; gap: 0.4rem;
  }
  .l2-tile--tray {
    background: linear-gradient(180deg, #fef3c7, #fbbf24);
    color: #78350f;
    border-color: #b45309;
    box-shadow: 0 3px 0 #92400e, 0 4px 12px rgba(180, 83, 9, 0.32);
    cursor: pointer;
  }
  .l2-tile--tray:hover { transform: translateY(-2px) scale(1.06); }
  .l2-tile--tray:active { transform: translateY(1px); box-shadow: 0 1px 0 #92400e; }
  .l2-tile-tray-hint {
    display: inline-flex; align-items: center; gap: 0.55rem;
    color: #cbd5e1;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
  }

  /* Combo HUD — top of Q2, climbs with every tile drop. */
  .l2-combo-hud {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    margin-bottom: 0.55rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #facc15, #f97316);
    color: #7c2d12;
    box-shadow: 0 3px 0 #c2410c, 0 6px 14px rgba(249, 115, 22, 0.3);
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .l2-combo-label { font-size: 0.7rem; }
  .l2-combo-count { font-size: 1.05rem; min-width: 1.2em; text-align: right; }
  .l2-combo-mult { font-size: 0.95rem; color: #b91c1c; }
  .l2-combo-pop { animation: l2ComboPop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 1; }
  @keyframes l2ComboPop {
    0%   { transform: scale(1)   rotate(0); }
    50%  { transform: scale(1.18) rotate(-3deg); }
    100% { transform: scale(1)   rotate(0); }
  }

  /* Floating combo numbers — fly up from the tile that was dropped. */
  .l2-combo-float {
    position: fixed;
    transform: translate(-50%, -100%);
    pointer-events: none;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: 'Fredoka', system-ui, sans-serif;
    text-align: center;
    animation: l2ComboFloat 1.1s ease-out forwards;
    text-shadow: 0 2px 6px rgba(0,0,0,0.4);
  }
  .l2-combo-float-pts {
    font-size: 1.6rem;
    font-weight: 900;
    color: #fde047;
  }
  .l2-combo-float-mult {
    font-size: 0.7rem;
    font-weight: 900;
    color: #fb923c;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @keyframes l2ComboFloat {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
    20%  { opacity: 1; transform: translate(-50%, -110%) scale(1.1); }
    100% { opacity: 0; transform: translate(-50%, -220%) scale(0.95); }
  }

  /* Kahoot 2-2 vibrant button with bouncy depth shadow. */
  .l2-kahoot-btn {
    --bg:  #3b82f6;
    --bgd: #1d4ed8;
    background: var(--bg);
    color: #fff;
    border-radius: 18px;
    padding: 18px 16px;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    text-align: center;
    box-shadow: 0 6px 0 var(--bgd), 0 10px 18px rgba(0,0,0,0.18);
    border: none;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s, opacity 0.15s;
    line-height: 1.2;
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 4px;
  }
  .l2-kahoot-btn:hover  { transform: translateY(2px); box-shadow: 0 4px 0 var(--bgd), 0 8px 14px rgba(0,0,0,0.18); }
  .l2-kahoot-btn:active { transform: translateY(5px); box-shadow: 0 1px 0 var(--bgd), 0 3px 6px rgba(0,0,0,0.18); }
  .l2-kahoot-btn:disabled { cursor: default; }

  /* Research-driven palette — Kahoot brand-aligned + WCAG contrast vs
     white text + 6 distinct hues under colour-blind simulation. Used
     by Q2/Q3/Q4 answer buttons. */
  .l2-kahoot-btn--red    { --bg: #ff3355; --bgd: #991b1b; } /* Kahoot red    */
  .l2-kahoot-btn--blue   { --bg: #1368ce; --bgd: #1e3a8a; } /* Kahoot denim  */
  .l2-kahoot-btn--green  { --bg: #26890c; --bgd: #14532d; } /* Kahoot bilbao */
  .l2-kahoot-btn--orange { --bg: #eb670f; --bgd: #9a3412; } /* Kahoot orange */
  .l2-kahoot-btn--purple { --bg: #864cbf; --bgd: #5b21b6; } /* Kahoot purple */
  .l2-kahoot-btn--teal   { --bg: #0891b2; --bgd: #155e75; } /* Cyan-teal     */
  /* Legacy aliases — kept so existing renderers (Q2 type, Q3 cn) stay
     working without a rename. Yellow + pink are deeper / more saturated
     than the previous Tailwind-500 stock so they don't visually clash
     with the gold selected halo. */
  .l2-kahoot-btn--yellow { --bg: #d97706; --bgd: #78350f; }
  .l2-kahoot-btn--pink   { --bg: #db2777; --bgd: #831843; }

  /* Selected state — multi-modal so the pick reads loud even on a
     printed-out screenshot AND under colour-blind simulation:
       1. White outline (5px) — universally contrasts against any
          saturated card colour.
       2. Dark navy band (9px box-shadow ring) — separates the white
          outline from the mint backdrop so it doesn't get lost.
       3. Gold halo (rgba) — pulses for motion cue.
       4. Check-mark badge (top-right) — non-colour indicator.
       5. Scale + lift (1.08) — depth cue.
     Hazim spec 2026-05-10 ("colour yang lebih sesuai untuk project
     mcm ni yang jelas"). */
  .l2-kahoot-btn[data-state="selected"] {
    outline: 5px solid #ffffff;
    outline-offset: 4px;
    transform: translateY(-4px) scale(1.08);
    box-shadow:
      0 11px 0 var(--bgd),
      0 0 0 9px #0f172a,
      0 0 0 16px rgba(253, 224, 71, 0.55),
      0 18px 28px rgba(0,0,0,0.35);
    position: relative;
    z-index: 2;
    animation: l2-kahoot-pulse 1.4s ease-in-out infinite;
  }
  .l2-kahoot-btn[data-state="selected"]::after {
    content: "\2713";
    position: absolute;
    top: -14px;
    right: -14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fde047;
    color: #78350f;
    font-weight: 900;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.30);
    border: 3px solid #fff;
  }
  @keyframes l2-kahoot-pulse {
    0%, 100% {
      box-shadow:
        0 11px 0 var(--bgd),
        0 0 0 9px #0f172a,
        0 0 0 16px rgba(253, 224, 71, 0.55),
        0 18px 28px rgba(0,0,0,0.35);
    }
    50% {
      box-shadow:
        0 11px 0 var(--bgd),
        0 0 0 9px #0f172a,
        0 0 0 22px rgba(253, 224, 71, 0.30),
        0 18px 28px rgba(0,0,0,0.35);
    }
  }
  .l2-kahoot-btn[data-state="correct"] { --bg: #22c55e; --bgd: #15803d; }
  .l2-kahoot-btn[data-state="wrong"]   { --bg: #ef4444; --bgd: #991b1b; animation: l2-kahoot-shake 0.4s; }
  .l2-kahoot-btn[data-state="faded"]   { opacity: 0.4; pointer-events: none; }
  /* Eliminated — research-driven multi-modal kill state per Hazim
     2026-05-10 ("dia tk buang jawapan player pilih salah tdi"):
     shake → desaturate → striped fill → diagonal "WRONG" stamp
     covering the whole option. NN/g says wrong-state opacity must be
     ≤ 0.4 with a non-colour cue; the previous 28 px corner ✕ relied
     on a single glyph that disappeared at projection distance.
     Sources cited in commit message. */
  @keyframes l2-elim-shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px) rotate(-0.4deg); }
    40% { transform: translateX(6px)  rotate(0.4deg); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }
  .l2-kahoot-btn[data-state="eliminated"] {
    --bg: #e2e8f0; --bgd: #94a3b8;
    color: #6b7280;
    cursor: not-allowed;
    pointer-events: none;
    position: relative;
    overflow: hidden;
    opacity: 0.32;
    filter: grayscale(1) blur(0.3px);
    background: repeating-linear-gradient(
      45deg, #e5e7eb 0 8px, #d1d5db 8px 16px) !important;
    text-decoration: line-through 3px #b91c1c;
    text-decoration-skip-ink: none;
    -webkit-box-decoration-break: clone;
            box-decoration-break: clone;
    box-shadow: 0 3px 0 #94a3b8;
    transition: opacity 0.4s ease, filter 0.4s ease;
    animation: l2-elim-shake 0.4s ease-out 1;
  }
  .l2-kahoot-btn[data-state="eliminated"]::after {
    content: "WRONG";
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font: 800 1.25rem/1 system-ui, -apple-system, sans-serif;
    letter-spacing: 0.18em;
    color: #b91c1c;
    background: rgba(255, 255, 255, 0.55);
    border: 3px dashed #b91c1c;
    transform: rotate(-6deg) scale(1.02);
    text-shadow: 0 1px 0 #fff, 0 2px 4px rgba(0,0,0,0.15);
    pointer-events: none;
  }

  .l2-kahoot-btn .l2-btn-sub {
    font-size: 0.7em;
    font-weight: 500;
    opacity: 0.85;
  }

  @keyframes l2-kahoot-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  /* Nav buttons (Submit / Back / Next). */
  .l2-nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 18px;
    gap: 12px;
  }
  .l2-nav-btn {
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    padding: 12px 26px;
    border-radius: 16px;
    transition: transform 0.15s, box-shadow 0.15s;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .l2-nav-btn--primary {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #fff;
    box-shadow: 0 5px 0 #1e3a8a, 0 8px 14px rgba(0,0,0,0.18);
  }
  .l2-nav-btn--primary:hover    { transform: translateY(2px); box-shadow: 0 3px 0 #1e3a8a, 0 6px 10px rgba(0,0,0,0.18); }
  .l2-nav-btn--primary:disabled {
    background: #cbd5e1;
    color: #64748b;
    box-shadow: 0 5px 0 #94a3b8;
    cursor: not-allowed;
  }
  .l2-nav-btn--secondary {
    background: #fff;
    color: #475569;
    border: 2px solid #cbd5e1;
    box-shadow: 0 3px 0 #cbd5e1;
  }
  .l2-nav-btn--secondary:hover { background: #f8fafc; transform: translateY(1px); box-shadow: 0 2px 0 #cbd5e1; }

  /* Top-left utility-icon cluster — Kahoot-mock vibe. The 4 buttons
     are decorative wraps around the existing AudioManager / settings
     hooks, sized so they live alongside the brand cluster on the HUD. */
  .l2-util-icons {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
  }
  .l2-util-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: rgba(255,255,255,0.16);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .l2-util-icon:hover { background: rgba(255,255,255,0.28); transform: translateY(-1px); }
  .l2-util-icon svg { width: 16px; height: 16px; }

  /* ============================================================
     Bouncy "+N points" toast — shown after a correct answer.
     ============================================================ */
  .l2-points-toast {
    position: fixed;
    top: 7%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    animation: l2-toast-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }
  /* Hazim 2026-05-11: the toast was previously at top:18% which sat
     directly over the Q5 formula box, hiding the "[Co(NH₃)…" prefix
     while only the tail "(ox)(bipy)]⁺" was visible behind it. Lifted
     to top:7% so the toast sits above the score bar / formula box
     and the chemistry notation stays fully readable through the
     celebration. */
  .l2-points-toast-inner {
    background: linear-gradient(135deg, #fde68a 0%, #f59e0b 70%, #d97706 100%);
    color: #78350f;
    padding: 36px 60px;
    border-radius: 32px;
    box-shadow: 0 22px 56px rgba(0,0,0,0.36), inset 0 -8px 0 rgba(0,0,0,0.14);
    text-align: center;
    border: 6px solid #fff;
    position: relative;
  }
  /* Big radiant glow halo behind the toast. */
  .l2-points-toast-inner::before {
    content: "";
    position: absolute;
    inset: -56px;
    background: radial-gradient(circle, rgba(253, 224, 71, 0.65) 0%, rgba(253, 224, 71, 0) 70%);
    border-radius: 50%;
    z-index: -1;
    animation: l2-toast-glow 1.6s ease-in-out infinite;
  }
  .l2-points-toast-label {
    display: block;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    opacity: 0.95;
  }
  .l2-points-toast-num {
    display: block;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    font-size: 4.8rem;
    line-height: 1.05;
    margin-top: 10px;
    text-shadow: 0 3px 0 rgba(255,255,255,0.5), 0 5px 12px rgba(120, 53, 15, 0.35);
  }
  .l2-points-toast-num--small {
    font-size: 3.2rem; /* "Correct!" wraps slimmer than "+N pts" */
  }
  /* Sparkle stars positioned around the toast. Bigger + more of them
     per Hazim 2026-05-10 spec ("sparkling tu nak lagi besar"). The
     drop-shadow gives a heavy gold halo so each star reads from a
     distance. */
  .l2-toast-spark {
    position: absolute;
    color: #fde047;
    filter: drop-shadow(0 0 14px rgba(253, 224, 71, 1)) drop-shadow(0 0 24px rgba(245, 158, 11, 0.85));
    animation: l2-toast-sparkle 1.2s ease-in-out infinite;
  }
  .l2-toast-spark svg { width: 100%; height: 100%; display: block; }
  .l2-toast-spark--tl { top: -48px; left: -48px;  width: 72px; height: 72px; animation-delay: 0s; }
  .l2-toast-spark--tr { top: -54px; right: -42px; width: 60px; height: 60px; animation-delay: 0.2s; }
  .l2-toast-spark--bl { bottom: -44px; left: -38px;  width: 64px; height: 64px; animation-delay: 0.4s; }
  .l2-toast-spark--br { bottom: -54px; right: -50px; width: 80px; height: 80px; animation-delay: 0.6s; }
  .l2-toast-spark--t  { top: -68px; left: 50%; transform: translateX(-50%); width: 56px; height: 56px; animation-delay: 0.3s; }
  .l2-toast-spark--l  { top: 40%; left: -56px; width: 50px; height: 50px; animation-delay: 0.15s; }
  .l2-toast-spark--r  { top: 40%; right: -56px; width: 50px; height: 50px; animation-delay: 0.55s; }
  @keyframes l2-toast-sparkle {
    0%, 100% { transform: scale(0.8) rotate(0deg); opacity: 0.4; }
    50%      { transform: scale(1.4) rotate(180deg); opacity: 1; }
  }
  .l2-toast-spark--t { /* override transform to keep horizontal centring */ }
  .l2-toast-spark--t {
    animation-name: l2-toast-sparkle-center;
  }
  @keyframes l2-toast-sparkle-center {
    0%, 100% { transform: translateX(-50%) scale(0.8) rotate(0deg); opacity: 0.4; }
    50%      { transform: translateX(-50%) scale(1.4) rotate(180deg); opacity: 1; }
  }
  @keyframes l2-toast-glow {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.12); }
  }
  /* Q4 image-only geometry cards. White card, big image, no labels.
     States mirror the kahoot button so selected/correct/wrong reads
     consistently across the wizard. */
  .geo-img-card {
    position: relative;
    background: #fff;
    border: 3px solid #cbd5e1;
    border-radius: 18px;
    padding: 12px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    box-shadow: 0 5px 0 rgba(0,0,0,0.08), 0 8px 16px rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .geo-img-card img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }
  .geo-img-card:hover {
    border-color: #3b82f6;
    transform: translateY(-2px);
    box-shadow: 0 7px 0 rgba(0,0,0,0.10), 0 12px 22px rgba(0,0,0,0.10);
  }
  .geo-img-card:disabled { cursor: default; }
  /* Hazim 2026-05-11: "buat yang clickable tu active" — the previous
     white-outline selected state was invisible on the white-background
     image cards. Strong amber background fill so a picked card is
     UNMISTAKABLY different from the unpicked ones. The molecule image
     overlays the new fill. Outline + thick depth shadow + pulse +
     check badge keep the multi-modal cues. */
  .geo-img-card[data-state="selected"] {
    background: #fde68a;
    border: 4px solid #d97706;
    outline: 4px solid #ffffff;
    outline-offset: 2px;
    transform: translateY(-4px) scale(1.06);
    box-shadow:
      0 0 0 9px #b45309,
      0 0 0 14px rgba(253, 224, 71, 0.6),
      0 16px 28px rgba(0,0,0,0.30);
    z-index: 2;
    animation: l2-kahoot-pulse 1.4s ease-in-out infinite;
  }
  .geo-img-card[data-state="selected"] img {
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.18));
  }
  .geo-img-card[data-state="selected"]::after {
    content: "\2713";
    position: absolute;
    top: -14px;
    right: -14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fde047;
    color: #78350f;
    font-weight: 900;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.30);
    border: 3px solid #fff;
    z-index: 3;
  }
  .geo-img-card[data-state="correct"] {
    border-color: #22c55e;
    box-shadow: 0 5px 0 #15803d, 0 0 0 4px rgba(34, 197, 94, 0.25);
    background: #f0fdf4;
  }
  .geo-img-card[data-state="wrong"] {
    border-color: #ef4444;
    box-shadow: 0 5px 0 #991b1b, 0 0 0 4px rgba(239, 68, 68, 0.22);
    background: #fef2f2;
    animation: l2-kahoot-shake 0.4s;
  }
  .geo-img-card[data-state="faded"] {
    opacity: 0.35;
    pointer-events: none;
    filter: grayscale(0.6);
  }

  /* Armed inventory ligand — research-driven (NN/g, Microsoft Visual
     Feedback, Smart Interface Design Patterns): the previous outline
     + check sat too quietly on a 54 px tile below the dominant 3D
     canvas — the player's eye was on the canvas, not the strip.
     Stronger pulse + animation pulls the eye, AND a cursor-following
     ghost preview travels into the canvas. Hazim 2026-05-10:
     "tak nampak player pilih mana". */
  .lig-drag-card[data-armed="true"] {
    outline: 4px solid #fbbf24;
    outline-offset: 3px;
    box-shadow: 0 0 0 8px rgba(251, 191, 36, 0.35), 0 8px 24px rgba(0,0,0,0.25);
    position: relative;
    z-index: 5;
    border-color: #fbbf24 !important;
    animation: l2-armed-pulse 1.1s ease-in-out infinite;
  }
  @keyframes l2-armed-pulse {
    0%, 100% { transform: translateY(0)    scale(1); }
    50%      { transform: translateY(-4px) scale(1.06); }
  }
  .lig-drag-card[data-armed="true"]::after {
    content: "\2713";
    position: absolute;
    top: -10px;
    right: -10px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #fbbf24;
    color: #78350f;
    font-weight: 900;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 8px rgba(0,0,0,0.30);
    border: 2px solid #fff;
  }

  /* Body cursor change while a ligand is armed — global "I'm holding
     something" feedback so the cursor looks intentional inside the
     3D canvas too. */
  body.l2-arming, body.l2-arming * { cursor: crosshair !important; }

  /* Cursor-following ghost preview. Shows a yellow-ringed pill with
     the ligand's sphere-color dot + name attached to the cursor while
     armed. This is the LOAD-BEARING fix — research finding: the cue
     must travel with the cursor into the 3D scene rather than sit
     isolated in the inventory strip. */
  #l2-arm-ghost {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    transform: translate(-50%, calc(-100% - 14px)) rotate(-3deg);
    background: #fff;
    border: 3px solid #fbbf24;
    border-radius: 14px;
    box-shadow: 0 8px 22px rgba(0,0,0,0.35);
    padding: 8px 14px;
    display: none;
    z-index: 9999;
    font: 700 0.95rem 'Fredoka', system-ui, sans-serif;
    color: #78350f;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }
  #l2-arm-ghost[data-on="1"] { display: inline-flex; }
  .l2-arm-ghost-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: inset 0 -3px 0 rgba(0,0,0,0.18), 0 0 0 2px #fff, 0 2px 6px rgba(0,0,0,0.25);
  }
  .l2-arm-ghost-name { font-size: 1rem; }

  /* Q5 chemistry formula box — Hazim 2026-05-11 follow-up: "taknak
     double line, nak inline je". Strategy: keep the formula on a
     SINGLE line at all times. The text starts at a comfortable
     2.4 rem and a JS ResizeObserver shrinks the font (in 0.5 px
     steps, floored at 12 px) only when the actual content overflows
     the pill's width. Short formulas keep the big font; long
     formulas auto-shrink just enough to fit on one line. */
  .l2-formula {
    font-size: clamp(1.25rem, 2.4vw, 2rem);
    line-height: 1.2;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    -webkit-box-decoration-break: clone;
            box-decoration-break: clone;
    width: 100%;
    max-width: 100%;
  }
  .l2-formula .nb { white-space: nowrap; }

  /* Hazim 2026-05-11: chemistry-notation brackets around the 3D
     scene with the complex's overall charge as a superscript on
     the top-right, mimicking [Co(NH₃)₃(H₂O)₃]³⁺ rendered around
     the live model. Pure-CSS pseudo-elements; pointer-events stay
     on the canvas. */
  /* Bracket frame: fixed vertical slot so canvas can't bleed into
     the picker. Right padding bumped to 88 px to give the charge
     pill its own dedicated gutter past the `]` bracket. */
  #l2-bracket-frame {
    position: relative;
    padding: 8px 88px 0 36px;
    flex: 0 0 auto;
    height: 42vh;
    min-height: 220px;
    max-height: 460px;
    overflow: hidden;
  }
  #l2-bracket-frame canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  #l2-bracket-frame::before,
  #l2-bracket-frame::after {
    content: "";
    position: absolute;
    top: 8px;
    bottom: 8px;
    width: 18px;
    border: 5px solid #0f172a;
    pointer-events: none;
    z-index: 4;
  }
  #l2-bracket-frame::before {
    left: 10px;
    border-right: none;
    border-radius: 6px 0 0 6px;
  }
  #l2-bracket-frame::after {
    right: 60px;
    border-left: none;
    border-radius: 0 6px 6px 0;
  }
  /* Charge superscript — sits in the 60 px gutter to the right of
     the `]` bracket. Bracket at right:60-78 (60+18 wide). Pill at
     right:6-50 (44 px wide max). 10 px clean gap between pill and
     bracket. Hazim 2026-05-11 follow-up: pill was still half on
     the bracket because the previous 36 px right offset gave the
     pill nowhere to land. */
  #l2-bracket-charge {
    position: absolute;
    top: 2px;
    right: 6px;
    /* Use inline-flex so + / − is GEOMETRICALLY centred inside the
       pill regardless of the glyph's own baseline. Hazim 2026-05-11:
       "+ / − duduk kt tengah bulatan please". `line-height: 1` was
       making the symbol sit low because the +/− glyph anchors near
       the cap-height, not the centre. min-width/min-height enforce a
       round shape; flex centring makes the character sit dead in
       the middle regardless of which character is rendered. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    min-height: 32px;
    padding: 0 8px;
    font-family: 'Fredoka', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(1rem, 1.8vw, 1.5rem);
    color: #0f172a;
    background: #fff;
    border-radius: 999px;
    border: 3px solid #0f172a;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    z-index: 6;
    line-height: 1;
    letter-spacing: 0.02em;
    white-space: nowrap;
    max-width: 64px;
    text-align: center;
  }
  #l2-bracket-charge.hidden { display: none; }
  #l2-bracket-charge[data-sign="positive"] { color: #b91c1c; border-color: #b91c1c; }
  #l2-bracket-charge[data-sign="negative"] { color: #1e40af; border-color: #1e40af; }
  #l2-bracket-charge[data-sign="neutral"]  { color: #047857; border-color: #047857; }

  /* Confetti rain — Hazim 2026-05-11 ("nak macam meriah, ade bunyi
     orang bersorak"). Pure-CSS Kahoot-podium-style colour rain that
     drops from above the viewport and falls past the bottom while
     swaying + rotating. JS spawns 60 pieces at random positions /
     delays / durations / colours. Container is fixed, pointer-events
     none so it doesn't intercept any clicks. */
  .l2-confetti-rain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 10000;
    overflow: hidden;
  }
  .l2-confetti-piece {
    position: absolute;
    top: -24px;
    width: 10px;
    height: 14px;
    border-radius: 2px;
    will-change: transform, opacity;
    animation-name: l2-confetti-fall, l2-confetti-sway;
    animation-timing-function: cubic-bezier(0.25, 0.55, 0.55, 1), ease-in-out;
    animation-iteration-count: 1, infinite;
    animation-fill-mode: forwards, none;
    animation-direction: normal, alternate;
  }
  @keyframes l2-confetti-fall {
    0%   { transform: translateY(0) rotate(0deg);    opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
  @keyframes l2-confetti-sway {
    0%   { margin-left: 0; }
    100% { margin-left: 30px; }
  }

  .l2-points-toast-fade { animation: l2-toast-out 0.6s ease-in forwards; }
  @keyframes l2-toast-pop {
    0%   { opacity: 0; transform: translateX(-50%) scale(0.4) rotate(-8deg); }
    55%  { opacity: 1; transform: translateX(-50%) scale(1.12) rotate(2deg); }
    80%  { transform: translateX(-50%) scale(0.96) rotate(-1deg); }
    100% { opacity: 1; transform: translateX(-50%) scale(1) rotate(0deg); }
  }
  @keyframes l2-toast-out {
    from { opacity: 1; transform: translateX(-50%) scale(1); }
    to   { opacity: 0; transform: translateX(-50%) scale(0.95) translateY(-12px); }
  }
</style>

