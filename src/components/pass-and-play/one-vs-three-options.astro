---
import CharacterPicker from "./character-picker.astro";
---

<section id="one-vs-three-options" class="space-y-5 hidden">
  <div>
    <h2 class="text-center text-xl">Enter player names</h2>
    <p class="text-center text-gray-600">Type names and pick blooks for 4 players.</p>
  </div>

  <div class="bg-gray-200 rounded-2xl p-4 space-y-3">
    <div>
      <label for="one-vs-three-p1-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 1</label>
      <input type="text" id="one-vs-three-p1-name" value="Player 1" placeholder="Player 1 Name" class="h-10 rounded-xl text-center w-full bg-white font-semibold" />
    </div>
    <div>
      <label for="one-vs-three-p2-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 2</label>
      <input type="text" id="one-vs-three-p2-name" value="Player 2" placeholder="Player 2 Name" class="h-10 rounded-xl text-center w-full bg-white font-semibold" />
    </div>
    <div>
      <label for="one-vs-three-p3-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 3</label>
      <input type="text" id="one-vs-three-p3-name" value="Player 3" placeholder="Player 3 Name" class="h-10 rounded-xl text-center w-full bg-white font-semibold" />
    </div>
    <div>
      <label for="one-vs-three-p4-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 4</label>
      <input type="text" id="one-vs-three-p4-name" value="Player 4" placeholder="Player 4 Name" class="h-10 rounded-xl text-center w-full bg-white font-semibold" />
    </div>
  </div>

  <CharacterPicker slot="p1" label="Player 1 blook" defaultId="panda" />
  <CharacterPicker slot="p2" label="Player 2 blook" defaultId="frog" />
  <CharacterPicker slot="p3" label="Player 3 blook" defaultId="dog" />
  <CharacterPicker slot="p4" label="Player 4 blook" defaultId="owl" />

  <button id="start-game-one-vs-three" class="bg-ludon-green text-white rounded-xl p-2.5 text-lg w-full">Start</button>
</section>

<script>
  // 4-player slots are permanent: Player 1=red, 2=blue, 3=yellow, 4=green.
  // No colour picker — blook character replaces the horse visually.
  const p1Input = document.getElementById("one-vs-three-p1-name") as HTMLInputElement | null;
  const p2Input = document.getElementById("one-vs-three-p2-name") as HTMLInputElement | null;
  const p3Input = document.getElementById("one-vs-three-p3-name") as HTMLInputElement | null;
  const p4Input = document.getElementById("one-vs-three-p4-name") as HTMLInputElement | null;
  const startButton = document.getElementById("start-game-one-vs-three") as HTMLButtonElement | null;

  function saveNames() {
    sessionStorage.setItem("one-vs-three-player-1-name", p1Input?.value?.trim() || "Player 1");
    sessionStorage.setItem("one-vs-three-player-2-name", p2Input?.value?.trim() || "Player 2");
    sessionStorage.setItem("one-vs-three-player-3-name", p3Input?.value?.trim() || "Player 3");
    sessionStorage.setItem("one-vs-three-player-4-name", p4Input?.value?.trim() || "Player 4");
  }
  saveNames();

  p1Input?.addEventListener("input", saveNames);
  p2Input?.addEventListener("input", saveNames);
  p3Input?.addEventListener("input", saveNames);
  p4Input?.addEventListener("input", saveNames);

  startButton?.addEventListener("click", () => {
    saveNames();
    if ((window as any).LoadingScreen?.showForNav) {
      (window as any).LoadingScreen.showForNav("/game-board", "Setting up your 4-player match…");
    } else {
      window.location.href = "/game-board";
    }
  });
</script>
