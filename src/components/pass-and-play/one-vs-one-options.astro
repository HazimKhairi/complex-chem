---
import CharacterPicker from "./character-picker.astro";
---

<section id="one-vs-one-options" class="space-y-5">
  <div>
    <h2 class="text-center text-xl">Enter player names</h2>
    <p class="text-center text-gray-600">Type each player's name and pick a blook.</p>
  </div>

  <div class="bg-gray-200 rounded-2xl p-4 space-y-3">
    <div>
      <label for="one-vs-one-p1-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 1</label>
      <input
        type="text"
        id="one-vs-one-p1-name"
        value="Player 1"
        placeholder="Player 1 Name"
        class="h-10 rounded-xl text-center w-full bg-white font-semibold"
      />
    </div>
    <div>
      <label for="one-vs-one-p2-name" class="block text-xs font-bold text-gray-700 mb-1 ml-1">Player 2</label>
      <input
        type="text"
        id="one-vs-one-p2-name"
        value="Player 2"
        placeholder="Player 2 Name"
        class="h-10 rounded-xl text-center w-full bg-white font-semibold"
      />
    </div>
  </div>

  <CharacterPicker slot="p1" label="Player 1 blook" defaultId="panda" />
  <CharacterPicker slot="p2" label="Player 2 blook" defaultId="frog" />

  <button id="start-game" class="bg-ludon-green text-white rounded-xl p-2.5 text-lg w-full">Start</button>
</section>

<script>
  // 2-player game uses slots Player 1 (red) and Player 2 (green)
  // behind the scenes. Blook character picker drives the visual.
  const p1Input = document.getElementById("one-vs-one-p1-name") as HTMLInputElement | null;
  const p2Input = document.getElementById("one-vs-one-p2-name") as HTMLInputElement | null;
  const startButton = document.getElementById("start-game") as HTMLButtonElement | null;

  // Default colour pair — fixed to red (slot 1) vs green (slot 4)
  sessionStorage.setItem("one-vs-one-horse-1", "red");
  sessionStorage.setItem("one-vs-one-horse-2", "green");

  function saveNames() {
    sessionStorage.setItem("one-vs-one-player-1-name", p1Input?.value?.trim() || "Player 1");
    sessionStorage.setItem("one-vs-one-player-2-name", p2Input?.value?.trim() || "Player 2");
  }
  saveNames();

  p1Input?.addEventListener("input", saveNames);
  p2Input?.addEventListener("input", saveNames);

  startButton?.addEventListener("click", () => {
    saveNames();
    if ((window as any).LoadingScreen?.showForNav) {
      (window as any).LoadingScreen.showForNav("/game-board", "Setting up your 2-player match…");
    } else {
      window.location.href = "/game-board";
    }
  });
</script>
