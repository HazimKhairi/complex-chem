---
/*
 * Pre-game popup — single step showing the official user-manual image
 * (rules + how to play). Emits `game-objective-dismissed` when closed
 * so the countdown can start. Uses sessionStorage to stay out of the
 * way on subsequent navigations within the same session.
 */
---

<div
  id="objective-modal"
  class="fixed inset-0 z-[60] flex items-center justify-center bg-black/80 backdrop-blur-sm p-3 sm:p-6"
>
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-3xl w-full max-h-[95vh] overflow-hidden flex flex-col">
    <div class="flex-1 overflow-auto p-3 sm:p-4 bg-gray-50">
      <img
        src="/assets/popups/user-manual.webp"
        alt="Complex Chem Quest — Rules & How To Play"
        class="w-full h-auto object-contain rounded-lg"
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="px-5 py-3 border-t border-gray-100 flex justify-between items-center gap-3 bg-white">
      <p class="text-xs text-gray-500">Take a moment to read the rules.</p>
      <button
        id="objective-next-btn"
        class="px-6 py-2.5 rounded-lg bg-ludon-blue hover:bg-blue-700 text-white font-semibold shadow"
        type="button"
      >
        Start Playing
      </button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("objective-modal");
  const nextBtn = document.getElementById("objective-next-btn");

  function dismiss() {
    modal?.classList.add("hidden");
    document.dispatchEvent(new CustomEvent("game-objective-dismissed"));
  }

  nextBtn?.addEventListener("click", dismiss);
</script>
