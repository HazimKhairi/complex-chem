---
interface Props {
  playerId: number;
  playerName: string;
  playerColor: string;
  points: number;
  isActive: boolean;
  inventoryCount: number;
}

const { playerId, playerName, playerColor, points, isActive, inventoryCount } = Astro.props;
---

<div
  class={`player-info p-4 rounded-lg border-4 transition-all ${isActive ? "border-yellow-400 shadow-lg scale-105" : "border-gray-300 opacity-70"}`}
  style={`background: linear-gradient(135deg, ${playerColor}22 0%, ${playerColor}11 100%);`}
  data-player-id={playerId}
>
  <div class="flex items-center gap-3 mb-2">
    <div
      class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl"
      style={`background: ${playerColor};`}
    >
      {playerId}
    </div>
    <div class="flex-1">
      <h3 class="font-bold text-lg text-gray-800">{playerName}</h3>
      <p class="text-sm text-gray-600">
        {isActive ? "⭐ Your Turn" : "Waiting..."}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-2 text-sm">
    <div class="bg-white/50 rounded p-2">
      <p class="text-gray-600 text-xs">Points</p>
      <p class="font-bold text-lg player-points">{points}</p>
    </div>
    <div class="bg-white/50 rounded p-2">
      <p class="text-gray-600 text-xs">Ligands</p>
      <p class="font-bold text-lg player-inventory-count">{inventoryCount}</p>
    </div>
  </div>

  {isActive && (
    <div class="mt-3">
      <button class="w-full bg-white/80 hover:bg-white rounded py-2 text-sm font-semibold view-inventory-btn">
        View Inventory 📦
      </button>
    </div>
  )}
</div>
