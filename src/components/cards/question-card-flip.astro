---
import { cn } from "../../lib/utils";
import type { QuestionCardImage } from "../../lib/data/question-cards-image";

interface Props {
  card: QuestionCardImage;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { card, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full aspect-[3/4]",
  md: "w-full aspect-[3/4]",
  lg: "w-full aspect-[3/4]",
};

const difficultyColors = {
  easy: "border-green-500",
  medium: "border-yellow-500",
  hard: "border-red-500",
};

const difficultyBadge = {
  easy: "bg-green-500",
  medium: "bg-yellow-500",
  hard: "bg-red-500",
};

// Calculate background position for the image crop
// Each image has note on left, question on right
const getBackgroundPosition = (side: "note" | "question") => {
  // Left side = note (0%), Right side = question (100%)
  return side === "note" ? "0% center" : "100% center";
};
---

<div class={cn("flip-card-container", sizeClasses[size], className)}>
  <div class="flip-card w-full h-full">
    <!-- Front: Did you know? (Note) -->
    <div
      class={cn(
        "flip-card-face flip-card-front absolute inset-0 rounded-lg border-4 overflow-hidden",
        difficultyColors[card.difficulty],
      )}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/question-cards/${card.imageFile}'); background-position: ${getBackgroundPosition("note")}; background-size: 200%;`}
      >
      </div>
      <!-- Badge overlay -->
      <div class="absolute top-2 right-2 px-3 py-1 rounded-full text-white text-xs font-bold" style={`background-color: ${difficultyBadge[card.difficulty]}`}>
        {card.difficulty.toUpperCase()} - {card.points} pts
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip
      </div>
    </div>

    <!-- Back: Question -->
    <div
      class={cn(
        "flip-card-face flip-card-back absolute inset-0 rounded-lg border-4 overflow-hidden",
        difficultyColors[card.difficulty],
      )}
    >
      <div
        class="w-full h-full bg-no-repeat"
        style={`background-image: url('/assets/question-cards/${card.imageFile}'); background-position: ${getBackgroundPosition("question")}; background-size: 200%;`}
      >
      </div>
      <!-- Badge overlay -->
      <div class="absolute top-2 right-2 px-3 py-1 rounded-full text-white text-xs font-bold" style={`background-color: ${difficultyBadge[card.difficulty]}`}>
        {card.difficulty.toUpperCase()} - {card.points} pts
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip back
      </div>
    </div>
  </div>
</div>

<style>
  .flip-card-container {
    perspective: 1000px;
    cursor: pointer;
  }

  .flip-card {
    transform-style: preserve-3d;
    transition: transform 0.6s;
    position: relative;
  }

  .flip-card-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .flip-card-back {
    transform: rotateY(180deg);
  }

  .flip-card-container.flipped .flip-card {
    transform: rotateY(180deg);
  }
</style>

<script>
  // Add click handlers to flip cards
  document.addEventListener("DOMContentLoaded", () => {
    const containers = document.querySelectorAll(".flip-card-container");
    containers.forEach((container) => {
      container.addEventListener("click", () => {
        container.classList.toggle("flipped");
      });
    });
  });
</script>
