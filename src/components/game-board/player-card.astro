---
interface Props {
  id: 1 | 2 | 3 | 4;
  playerName: string;
  reverse?: boolean;
}

const { id, playerName, reverse = false } = Astro.props;
---

<div id={`player-${id}-area`} class="inline-flex flex-col items-center">
  <!-- Player Card Container -->
  <div class={`flex items-center gap-1 ${reverse ? "flex-row-reverse" : ""}`}>
    <!-- Player Avatar Column -->
    <div class="flex flex-col items-center gap-1">
      <!-- Avatar -->
      <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl bg-white shadow-md overflow-hidden border-2 border-gray-200">
        <img id={`player-${id}-image`} class="w-full h-full object-cover" alt={playerName} />
      </div>

      <!-- Player Name -->
      <span id={`player-${id}-name`} class="text-xs sm:text-sm font-bold text-gray-800 text-center leading-tight max-w-[76px] truncate">
        {playerName}
      </span>

      <!-- Points Badge - INSIDE container -->
      <div class="bg-yellow-500 rounded-full px-3 py-1 shadow-md border border-yellow-600 min-w-[60px] flex items-center justify-center">
        <span class="text-xs sm:text-sm font-black text-gray-900 whitespace-nowrap">
          <span id={`player-${id}-points`} class="text-base sm:text-lg">0</span>
          <span class="text-[10px] ml-0.5">pts</span>
        </span>
      </div>
    </div>

    <!-- Dice Container -->
    <div class={`w-12 h-12 sm:w-14 sm:h-14 ${reverse ? "rounded-l-md" : "rounded-r-md"} bg-gray-800 shadow-md flex items-center justify-center`}>
      <img id={`player-${id}-dice`} class="w-10 h-10 sm:w-12 sm:h-12 object-contain player-dice" />
    </div>

    <!-- Arrow Indicator -->
    <img id={`player-${id}-dice-arrow`} class={`h-10 sm:h-12 object-contain ${reverse ? "" : "rotate-180"}`} />
  </div>
</div>

<script>
  import { getPlayerAvatar, getPlayerColor } from "../../lib/utils";

  const playerOneImage = document.getElementById(`player-1-image`);
  const playerTwoImage = document.getElementById(`player-2-image`);
  const playerThreeImage = document.getElementById(`player-3-image`);
  const playerFourImage = document.getElementById(`player-4-image`);
  const winnerOneImage = document.getElementById(`winner-1-image`);
  const winnerTwoImage = document.getElementById(`winner-2-image`);
  const winnerThreeImage = document.getElementById(`winner-3-image`);
  const winnerFourImage = document.getElementById(`winner-4-image`);

  const gameMode = sessionStorage.getItem("game-option");
  const playerOneName = sessionStorage.getItem(`${gameMode}-player-1-name`) ?? "Player 1";
  const playerTwoName = sessionStorage.getItem(`${gameMode}-player-2-name`) ?? "Player 2";
  const playerThreeName = sessionStorage.getItem(`${gameMode}-player-3-name`) ?? "Player 3";
  const playerFourName = sessionStorage.getItem(`${gameMode}-player-4-name`) ?? "Player 4";

  const playerOneAvatar = getPlayerAvatar({
    playerName: playerOneName,
    playerColor: getPlayerColor(1),
  });
  const playerTwoAvatar = getPlayerAvatar({
    playerName: playerTwoName,
    playerColor: getPlayerColor(2),
    reverse: true,
  });
  const playerThreeAvatar = getPlayerAvatar({
    playerName: playerThreeName,
    playerColor: getPlayerColor(3),
  });
  const playerFourAvatar = getPlayerAvatar({
    playerName: playerFourName,
    playerColor: getPlayerColor(4),
    reverse: true,
  });

  // Helper function to create fallback SVG avatar
  function createFallbackAvatar(name, color) {
    const initials = name.slice(0, 2).toUpperCase();

    return `data:image/svg+xml,${encodeURIComponent(`
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
        <rect width="100" height="100" fill="#${color}" rx="12"/>
        <text x="50" y="65" font-size="40" text-anchor="middle" fill="white" font-family="sans-serif" font-weight="bold">${initials}</text>
      </svg>
    `)}`;
  }

  // Set avatars with error fallback
  function setAvatarWithFallback(img, avatarUrl, name, color) {
    if (!img) return;

    img.setAttribute("src", avatarUrl);

    // Add error handler to use fallback SVG if API fails
    img.onerror = function() {
      console.log(`⚠️ Failed to load avatar from API, using fallback for ${name}`);
      img.src = createFallbackAvatar(name, color);
      img.onerror = null; // Prevent infinite loop
    };
  }

  setAvatarWithFallback(playerOneImage, playerOneAvatar, playerOneName, getPlayerColor(1));
  setAvatarWithFallback(playerTwoImage, playerTwoAvatar, playerTwoName, getPlayerColor(2));
  setAvatarWithFallback(playerThreeImage, playerThreeAvatar, playerThreeName, getPlayerColor(3));
  setAvatarWithFallback(playerFourImage, playerFourAvatar, playerFourName, getPlayerColor(4));
  setAvatarWithFallback(winnerOneImage, playerOneAvatar, playerOneName, getPlayerColor(1));
  setAvatarWithFallback(winnerTwoImage, playerTwoAvatar, playerTwoName, getPlayerColor(2));
  setAvatarWithFallback(winnerThreeImage, playerThreeAvatar, playerThreeName, getPlayerColor(3));
  setAvatarWithFallback(winnerFourImage, playerFourAvatar, playerFourName, getPlayerColor(4));
</script>
