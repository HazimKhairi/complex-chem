---
import { cn } from "../../lib/utils";
---

<table
  class={cn(
    "path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:w-[22.5px] [&_td]:h-[22.5px] [&_img]:w-[9px] [&_img]:mx-auto",
  )}
>
  <tr>
    <td class="r11 b50 y24 g37"><span class="text-[8px] text-white">phen</span></td>
    <td class="r12 b51 y25 g38 bg-[url('/arrows/blue.png')] bg-contain"></td>
    <td class="r13 y26 g39"><span class="text-[8px] text-white">NH₃</span></td>
  </tr>
  <tr>
    <td class="r10 b49 y23 g36"><span class="text-[8px] text-white">ox</span></td>
    <td class="b52 bg-sky-300"></td>
    <td class="r14 b1 y27 g40 bg-sky-300"></td>
  </tr>
  <tr>
    <td class="r9 b48 y22 g35"><span class="text-[8px] text-white">CI</span></td>
    <td class="b53 bg-sky-300"></td>
    <td class="r15 b2 y28 g41"><span class="text-[8px] text-white">py</span></td>
  </tr>
  <tr>
    <td
      class="r8 b47 y21 g34"
      style="background: #ef4444 url('/complexes/3.png') center/cover no-repeat !important;"
