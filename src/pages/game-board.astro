---
import Layout from "../layouts/Layout.astro";
import PlayerCard from "../components/game-board/player-card.astro";
import LudoBoard from "../components/game-board/ludo-board.astro";
import GameAudio from "../components/game-audio.astro";
import WinnersModel from "../components/game-board/winners-model.astro";
import GameStartCountdown from "../components/game-board/game-start-countdown.astro";
import GameAssets from "../components/game-assets.astro";
import LigandBox from "../components/game-board/ligand-box.astro";
import LigandModal from "../components/game/ligand-modal.astro";
import QuestionModal from "../components/game/question-modal.astro";
import FateModal from "../components/game/fate-modal.astro";
---

<Layout>
  <main class="flex justify-center items-center min-h-dvh p-2 sm:p-4 overflow-hidden">
    <!-- Landscape Mode Required Overlay (Mobile Only) -->
    <div
      id="rotate-overlay"
      class="fixed inset-0 bg-gray-900 bg-opacity-95 z-[9999] flex-col items-center justify-center gap-6 p-8 hidden"
    >
      <div class="text-center space-y-6">
        <!-- Rotate Icon -->
        <div class="flex justify-center">
          <svg class="w-24 h-24 text-amber-400 animate-[spin_3s_ease-in-out_infinite]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>

        <!-- Message -->
        <div class="space-y-3">
          <h2 class="text-2xl font-bold text-white">Rotate Your Device</h2>
          <p class="text-lg text-gray-300">Please rotate your device to landscape mode to play</p>
          <p class="text-base text-amber-400 font-semibold">📱 → 🔄 → 🎮</p>
        </div>
      </div>
    </div>

    <WinnersModel />
    <section id="game-container" class="transform-origin-center">
      <!-- Top Section: Players + Ligand Boxes -->
      <section class="flex flex-col items-center mb-1 sm:mb-2 gap-2 sm:gap-3">
        <!-- Top Ligand Boxes -->
        <div class="flex justify-between gap-2 sm:gap-4 md:gap-6 w-full max-w-[280px] sm:max-w-[320px]">
          <LigandBox playerId={1} />
          <LigandBox playerId={2} />
        </div>

        <!-- Top Players -->
        <div class="flex justify-between w-full max-w-[280px] sm:max-w-[320px] player-area">
          <PlayerCard id={1} playerName="Player 1" />
          <PlayerCard id={2} playerName="Player 2" reverse />
        </div>
      </section>

      <LudoBoard />

      <!-- Bottom Section: Players + Ligand Boxes -->
      <section class="flex flex-col items-center mt-1 sm:mt-2 gap-2 sm:gap-3">
        <!-- Bottom Players -->
        <div class="flex justify-between w-full max-w-[280px] sm:max-w-[320px] player-area">
          <PlayerCard id={3} playerName="Player 3" />
          <PlayerCard id={4} playerName="Player 4" reverse />
        </div>

        <!-- Bottom Ligand Boxes -->
        <div class="flex justify-between gap-2 sm:gap-4 md:gap-6 w-full max-w-[280px] sm:max-w-[320px]">
          <LigandBox playerId={3} />
          <LigandBox playerId={4} />
        </div>
      </section>
    </section>
    <GameAudio />
    <GameAssets />
    <GameStartCountdown />

    <!-- Game Modals -->
    <LigandModal />
    <QuestionModal />
    <FateModal />
  </main>
</Layout>

<script>
  // Load game script based on selected option
  const gameOption = sessionStorage.getItem("game-option");
  const script = document.createElement("script");
  script.src = `scripts/${gameOption}.js`;
  script.type = "application/javascript";
  document.head.appendChild(script);

  // Load game mechanics script with beautiful cards
  const mechanicsScript = document.createElement("script");
  mechanicsScript.src = "scripts/game-mechanics-cards.js";
  mechanicsScript.type = "application/javascript";
  document.head.appendChild(mechanicsScript);

  // Load game orchestrator and supporting systems
  // These coordinate all game mechanics together
  const tileDetectorScript = document.createElement("script");
  tileDetectorScript.src = "scripts/tile-detector.js";
  tileDetectorScript.type = "application/javascript";
  document.head.appendChild(tileDetectorScript);

  const turnManagerScript = document.createElement("script");
  turnManagerScript.src = "scripts/turn-manager.js";
  turnManagerScript.type = "application/javascript";
  document.head.appendChild(turnManagerScript);

  const winCheckerScript = document.createElement("script");
  winCheckerScript.src = "scripts/win-checker.js";
  winCheckerScript.type = "application/javascript";
  document.head.appendChild(winCheckerScript);

  // Load orchestrator LAST (after all dependencies)
  const orchestratorScript = document.createElement("script");
  orchestratorScript.src = "scripts/game-orchestrator.js";
  orchestratorScript.type = "application/javascript";
  document.head.appendChild(orchestratorScript);

  // Optimize game size for screen - AGGRESSIVE scaling
  function optimizeGameSize() {
    const container = document.getElementById("game-container");
    if (!container) return;

    // Reset transform to get natural size
    container.style.transform = "";

    // Get viewport dimensions
    const viewportHeight = window.innerHeight;
    const viewportWidth = window.innerWidth;

    // Get container dimensions
    const containerHeight = container.offsetHeight;
    const containerWidth = container.offsetWidth;

    // AGGRESSIVE scaling - use almost ALL viewport space
    const isMobile = viewportWidth < 640; // Tailwind 'sm' breakpoint
    const isTablet = viewportWidth >= 640 && viewportWidth < 1024; // Tailwind 'md' to 'lg'

    // Much higher padding factors to fill screen
    const paddingFactor = isMobile ? 0.96 : isTablet ? 0.94 : 0.92;

    const scaleHeight = (viewportHeight * paddingFactor) / containerHeight;
    const scaleWidth = (viewportWidth * paddingFactor) / containerWidth;

    // Use the smaller scale to ensure everything fits
    const scale = Math.min(scaleHeight, scaleWidth);

    // Apply scale - allow scaling UP to 2x for large screens, minimum 0.4 for tiny screens
    const finalScale = Math.max(0.4, Math.min(2.0, scale));
    container.style.transform = `scale(${finalScale})`;

    console.log(`Viewport: ${viewportWidth}x${viewportHeight}, Container: ${containerWidth}x${containerHeight}, Scale: ${finalScale.toFixed(2)}`);
  }

  // Run on load and resize with debounce
  let resizeTimeout;
  window.addEventListener("DOMContentLoaded", optimizeGameSize);
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(optimizeGameSize, 100);
  });

  // ========================================
  // MOBILE LANDSCAPE MODE ENFORCEMENT
  // ========================================
  function checkOrientation() {
    const rotateOverlay = document.getElementById("rotate-overlay");
    if (!rotateOverlay) return;

    const isMobile = window.innerWidth < 640; // Tailwind 'sm' breakpoint
    const isPortrait = window.innerHeight > window.innerWidth;

    // Show overlay ONLY if mobile AND portrait
    if (isMobile && isPortrait) {
      rotateOverlay.style.display = "flex";
      // Prevent game interaction
      document.getElementById("game-container")?.style.setProperty("pointer-events", "none");
    } else {
      rotateOverlay.style.display = "none";
      // Allow game interaction
      document.getElementById("game-container")?.style.setProperty("pointer-events", "auto");
    }
  }

  // Check on load and orientation change
  window.addEventListener("DOMContentLoaded", checkOrientation);
  window.addEventListener("resize", checkOrientation);
  window.addEventListener("orientationchange", checkOrientation);

  // Also check periodically for devices that don't fire orientationchange
  setInterval(checkOrientation, 500);
</script>
