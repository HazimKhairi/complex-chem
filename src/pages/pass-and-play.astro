---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

import { cn } from "../lib/utils";
import SoloOptions from "../components/pass-and-play/solo-options.astro";
import OneVsOneOptions from "../components/pass-and-play/one-vs-one-options.astro";
import OneVsTwoOptions from "../components/pass-and-play/one-vs-two-options.astro";
import OneVsThreeOptions from "../components/pass-and-play/one-vs-three-options.astro";
import SelectGameMode from "../components/select-game-mode.astro";
import LoadingScreen from "../components/loading-screen.astro";
---

<Layout>
  <LoadingScreen />
  <main class="relative flex justify-center items-center min-h-screen p-2 bg-azure w-[95%] mx-auto">
    <a
      href="/"
      class="absolute top-4 left-4 z-10 flex items-center gap-1.5 px-3 py-2 rounded-lg bg-white shadow-md hover:shadow-lg text-ludon-blue font-semibold text-sm"
      aria-label="Back to home"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Home
    </a>
    <div class="rounded-2xl shadow-md bg-white px-5 sm:px-10 py-5 w-full max-w-lg">
      <SelectGameMode includeSolo={true} />
      <SoloOptions />
      <OneVsOneOptions />
      <OneVsTwoOptions />
      <OneVsThreeOptions />
    </div>
  </main>
</Layout>

<!-- AudioManager needed for character-picker hover/select SFX -->
<script is:inline src="/scripts/audio-manager.js"></script>

<script>
  // Wipe everything from any previous run so the next game starts fresh
  // (piece positions, ligand inventory, scores, level-2 finals, …).
  // Without this, opening pass-and-play after finishing a game would
  // carry over stale state and the new piece would jump past home.
  try {
    sessionStorage.clear();
  } catch (e) {}
  sessionStorage.setItem("computer", "false");
</script>
