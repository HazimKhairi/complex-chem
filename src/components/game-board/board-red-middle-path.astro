---
import { cn } from "../../lib/utils";
---

<table
  class={cn(
    "middle-table path bg-gray-700",
    "[&_td]:border [&_td]:border-black [&_td]:relative",
    "[&_td]:w-[36px] [&_td]:h-[36px] [&_td]:sm:w-[38px] [&_td]:sm:h-[38px] [&_td]:md:w-[40px] [&_td]:md:h-[40px] [&_td]:lg:w-[42px] [&_td]:lg:h-[42px]",
    "[&_img]:w-[22px] [&_img]:sm:w-[24px] [&_img]:md:w-[26px] [&_img]:lg:w-[28px]",
    "[&_img]:mx-auto [&_img]:relative [&_img]:z-20 [&_img]:drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)]",
    "border-collapse m-0 p-0",
  )}
>
  <!-- LEFT ARM — between top-left (green) and bottom-left (red) home corners.
       Per latest spec (image #27), per-cell layout:
         Top    : START (green's, kept) | H₂O | ⚠ (fate) | complex | phen
         Winning: g52-g56 (green's stretch, no labels)
         Bottom : NH₃ | acac | complex | ⚠ (fate) | O²⁻
  -->
  <tr>
    <td class="g1 y40 r14 b27 start-tile start-tile-green"
      ><span
        class="start-label text-[8px] sm:text-[9px] font-black text-white flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none tracking-tighter"
        >START</span
      ></td
    >
    <td class="g2 y41 r15 b28" style="background-color:#fc0404"
      ><span
        class="text-[10px] text-white font-black flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none [text-shadow:_0_1px_2px_rgba(0,0,0,0.7)]"
        >H₂O</span
      ></td
    >
    <td
      class="g3 y42 r16 b29"
      style="background: #ef4444 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td
      class="g4 y43 r17 b30"
      style="background: #fcbc04 url('/complexes/7.png') center/cover no-repeat !important;"
    ></td>
    <td class="g5 y44 r18 b31" style="background-color:#046cfc"
      ><span
        class="text-[10px] text-white font-black flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none [text-shadow:_0_1px_2px_rgba(0,0,0,0.7)]"
        >phen</span
      ></td
    >
  </tr>
  <tr class="middle-row-green">
    <td class="g52 " style="background-color:#0cc704"></td>
    <td class="g53 " style="background-color:#0cc704"></td>
    <td class="g54 " style="background-color:#0cc704"></td>
    <td class="g55 " style="background-color:#0cc704"></td>
    <td class="g56 " style="background-color:#0cc704"></td>
  </tr>
  <tr>
    <td class="g50 y37 r11 b24" style="background-color:#046cfc"
      ><span
        class="text-[10px] text-white font-black flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none [text-shadow:_0_1px_2px_rgba(0,0,0,0.7)]"
        >NH₃</span
      ></td
    >
    <td class="g49 y36 r10 b23" style="background-color:#fc0404"
      ><span
        class="text-[10px] text-white font-black flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none [text-shadow:_0_1px_2px_rgba(0,0,0,0.7)]"
        >acac</span
      ></td
    >
    <td
      class="g48 y35 r9 b22"
      style="background: #ef4444 url('/complexes/8.png') center/cover no-repeat !important;"
    ></td>
    <td
      class="g47 y34 r8 b21"
      style="background: #ef4444 url('/complexes/fate_card.png') center/cover no-repeat !important;"
    ></td>
    <td class="g46 y33 r7 b20" style="background-color:#fc0404"
      ><span
        class="text-[10px] text-white font-black flex items-center justify-center h-full absolute inset-0 z-0 pointer-events-none [text-shadow:_0_1px_2px_rgba(0,0,0,0.7)]"
        >O²⁻</span
      ></td
    >
  </tr>
</table>
