---
interface Props {
  playerId: 1 | 2 | 3 | 4;
}

const { playerId } = Astro.props;
---

<div class="bg-white rounded-lg p-2 sm:p-3 w-32 sm:w-36 md:w-40 shadow-sm">
  <h3 class="text-[10px] sm:text-xs font-bold text-gray-800 mb-1 sm:mb-2 text-center">Ligands</h3>
  <div id={`ligand-display-${playerId}`} class="grid grid-cols-3 gap-1 sm:gap-1.5 max-h-20 sm:max-h-24 overflow-y-auto">
    <!-- Ligand mini cards will appear here (max 9 visible, then scroll) -->
  </div>
</div>

<style>
  /* Custom scrollbar for ligand display */
  [id^="ligand-display-"]::-webkit-scrollbar {
    width: 4px;
  }
  [id^="ligand-display-"]::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 2px;
  }
  [id^="ligand-display-"]::-webkit-scrollbar-thumb {
    background: #10b981;
    border-radius: 2px;
  }
  [id^="ligand-display-"]::-webkit-scrollbar-thumb:hover {
    background: #059669;
  }
</style>
