---
import { cn } from "../../lib/utils";
import type { Ligand } from "../../lib/data/ligands";

interface Props {
  ligand: Ligand;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { ligand, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full aspect-[3/4]",
  md: "w-full aspect-[3/4]",
  lg: "w-full aspect-[3/4]",
};

// Front + back are now physically split via scripts/crop-ligand-cards.mjs
// into /assets/ligand-cards/front/<file> and /back/<file>, tightly
// trimmed of white padding. Render each side as bg-contain/center so
// the card sits perfectly centred without any 200% / 0%-100% offset
// hack — Hazim 2026-05-10 spec.
---

<div class={cn("ligand-flip-card-container", sizeClasses[size], className)}>
  <div class="ligand-flip-card w-full h-full">
    <!-- Front: Logo -->
    <div
      class={cn(
        "ligand-flip-card-face ligand-flip-card-front absolute inset-0 rounded-lg border-4 overflow-hidden bg-white",
      )}
      style={`border-color: ${ligand.color}`}
    >
      <div
        class="w-full h-full bg-no-repeat bg-contain bg-center"
        style={`background-image: url('/assets/ligand-cards/front/${ligand.imageFile}');`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip
      </div>
    </div>

    <!-- Back: Description -->
    <div
      class={cn(
        "ligand-flip-card-face ligand-flip-card-back absolute inset-0 rounded-lg border-4 overflow-hidden bg-white",
      )}
      style={`border-color: ${ligand.color}`}
    >
      <div
        class="w-full h-full bg-no-repeat bg-contain bg-center"
        style={`background-image: url('/assets/ligand-cards/back/${ligand.imageFile}');`}
      >
      </div>
      <div class="absolute bottom-2 right-2 px-3 py-1 bg-black/70 text-white text-xs rounded">
        Click to flip back
      </div>
    </div>
  </div>
</div>

<style>
  .ligand-flip-card-container {
    perspective: 1000px;
    cursor: pointer;
  }

  .ligand-flip-card {
    transform-style: preserve-3d;
    transition: transform 0.6s;
    position: relative;
  }

  .ligand-flip-card-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .ligand-flip-card-back {
    transform: rotateY(180deg);
  }

  .ligand-flip-card-container.flipped .ligand-flip-card {
    transform: rotateY(180deg);
  }
</style>

<script>
  // Add click handlers to ligand flip cards
  document.addEventListener("DOMContentLoaded", () => {
    const containers = document.querySelectorAll(".ligand-flip-card-container");
    containers.forEach((container) => {
      container.addEventListener("click", () => {
        container.classList.toggle("flipped");
      });
    });
  });
</script>
