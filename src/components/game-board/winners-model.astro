---
/*
 * Level 1 completion card. NOT the final podium — the Kahoot-style
 * podium only appears at the END of Level 2 (see LevelTwoPodium).
 * This just confirms each finisher and gates the Continue-to-Level-2
 * button until everyone has crossed the finish line.
 */
---

<div
  id="winners"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 overflow-y-auto"
  style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(6px);"
>
  <div class="relative bg-white rounded-3xl shadow-2xl max-w-md w-full p-6 sm:p-8">
    <img class="h-16 mx-auto mb-3" src="/logo.png" alt="Complex Chem Quest" />

    <h1 class="text-center text-xl sm:text-2xl font-black text-slate-900 mb-1">
      Level 1 Complete!
    </h1>
    <p id="winners-subtitle" class="text-center text-slate-500 text-sm mb-5">
      Waiting for everyone to finish…
    </p>

    <div id="winners-list" class="space-y-2 mb-6">
      <!-- Populated by win-checker.js via #winner-N-name / #winner-N-image -->
    </div>

    <div class="flex gap-3 justify-center">
      <button
        type="button"
        onclick="location.href='/'"
        class="bg-slate-200 hover:bg-slate-300 text-slate-800 px-4 py-2.5 rounded-xl font-semibold transition-colors"
      >
        Menu
      </button>
      <button
        type="button"
        id="continue-level-2"
        onclick="(window.LoadingScreen?.showForNav ? window.LoadingScreen.showForNav('/level-2', 'Preparing Level 2…') : (location.href='/level-2'))"
        class="bg-ludon-blue hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl font-bold shadow transition-colors animate-pulse"
      >
        Continue to Level 2 →
      </button>
    </div>
  </div>
</div>

<style>
  #winners.flex { display: flex !important; }
</style>

<script>
  /*
   * win-checker.js expects #winner-N-name and #winner-N-image to exist
   * so updateWinnersModal can write into them. Provide them as hidden
   * shim nodes PLUS synthesize a visible list from the same data.
   * Expose window.__podiumRender as a no-op stub here since the podium
   * now lives at Level 2 end.
   */
  const root = document.getElementById("winners")!;

  // Shim hidden nodes for win-checker's legacy writes
  const shim = document.createElement("div");
  shim.style.display = "none";
  for (let n = 1; n <= 4; n++) {
    shim.innerHTML += `
      <div id="winner-${n}">
        <span id="winner-${n}-name"></span>
        <img id="winner-${n}-image" />
      </div>`;
  }
  root.appendChild(shim);

  // Render the visible list from the winners the shim receives
  (window as any).__podiumRender = function (winners: Array<{ playerId: number; playerName: string; score: number }>) {
    const list = document.getElementById("winners-list");
    const subtitle = document.getElementById("winners-subtitle");
    if (!list) return;

    // Blook src from session
    const blookSrc = (playerId: number) => {
      const charId = sessionStorage.getItem(`character-p${playerId}`);
      return charId ? `/characters/blook/${charId}.png` : "/horses/red.png";
    };

    const medalColor = ["bg-amber-400 text-amber-900", "bg-slate-300 text-slate-800", "bg-orange-500 text-white"];

    list.innerHTML = winners
      .map((w, i) => {
        const medal = medalColor[i] || "bg-slate-200 text-slate-700";
        return `
          <div class="flex items-center gap-3 rounded-xl border-2 border-slate-100 bg-slate-50 p-2.5">
            <div class="w-8 h-8 rounded-full ${medal} flex items-center justify-center font-black text-sm">
              ${i + 1}
            </div>
            <img src="${blookSrc(w.playerId)}" class="w-10 h-10 object-contain rounded-lg bg-white shadow-sm p-1" alt="${w.playerName}" />
            <div class="flex-1 min-w-0">
              <p class="font-bold text-slate-900 truncate">${w.playerName}</p>
              <p class="text-xs text-slate-500">Level 1 done</p>
            </div>
            <span class="font-black text-slate-700 tabular-nums">${w.score}</span>
          </div>
        `;
      })
      .join("");

    if (subtitle) {
      subtitle.textContent = "Great work — head into Level 2 to build your complex.";
    }
  };
</script>
