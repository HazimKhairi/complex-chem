---
import { Image } from "astro:assets";
import { cn } from "../../lib/utils";

interface Props {
  id: 1 | 2 | 3 | 4;
  horseImg: ImageMetadata;
  horseColor: "red" | "blue" | "green" | "yellow";
}

const { id, horseImg, horseColor } = Astro.props;
const firstColorLetter = horseColor.charAt(0);

// Bold home colors per spec — saturated, not pastel.
const HOME_COLOR: Record<string, string> = {
  red:    "#fc0404",
  blue:   "#046cfc",
  yellow: "#fcbc04",
  green:  "#0cc704",
};
const homeBg = HOME_COLOR[horseColor] || "#fc0404";
---

<div
  id={`player-${id}`}
  style={`background-color: ${homeBg}; border-color: ${homeBg};`}
  class={cn(
    "player-home-area",
    // +1px over the naive "5 × cell-size" so the home matches the
    // adjacent path table, which is `5 × cell + 1px` under
    // border-collapse (the leftmost cell border doesn't merge with
    // anything). Without this +1, the arm hangs ~1px past the home
    // corner on each side and shows a visible step at the joint,
    // amplified by #game-container's 1.36× transform.
    "w-[181px] h-[181px] sm:w-[191px] sm:h-[191px] md:w-[201px] md:h-[201px] lg:w-[211px] lg:h-[211px]",
    // box-border (default) so the border is INCLUDED in the home's outer
    // height — keeps the home flush with the adjacent middle path table
    // (the path is also border-box). Was box-content, which pushed the
    // outer height 2px past the path and showed a horizontal gap below
    // the home corners.
    "text-gray-500 text-sm box-border flex justify-center items-center shrink-0",
    id === 1 && "border-t-2 border-l-2 rounded-tl-[5px]",
    id === 2 && "border-t-2 border-r-2 rounded-tr-[5px]",
    id === 3 && "border-b-2 border-l-2 rounded-bl-[5px]",
    id === 4 && "border-b-2 border-r-2 rounded-br-[5px]"
  )}
>
  <!-- Single Piece Mode: Only 1 piece per player (h1) -->
  <div
    class="flex justify-center items-center p-3 rounded-sm bg-white bg-shadow w-[80px] h-[80px] sm:w-[84px] sm:h-[84px] md:w-[88px] md:h-[88px] lg:w-[92px] lg:h-[92px]"
  >
    <div class="flex justify-center items-center w-[52px] h-[52px] sm:w-[56px] sm:h-[56px] md:w-[60px] md:h-[60px] lg:w-[64px] lg:h-[64px] rounded-full bg-gray-200">
      <Image
        class={`${firstColorLetter}h1 w-5 sm:w-[22px] md:w-6 lg:w-[26px]`}
        id={`${firstColorLetter}h1`}
        src={horseImg}
        alt="Player Horse"
      />
    </div>
  </div>
</div>
