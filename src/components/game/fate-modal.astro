---

<div id="fate-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 text-center">
    <div class="mb-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-2">🔺 Fate Card!</h2>
      <p class="text-gray-600">Destiny has chosen...</p>
    </div>

    <div id="fate-card-container" class="mb-6">
      <!-- Fate card will be inserted here -->
    </div>

    <button id="continue-fate-btn" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-lg transition-colors">
      Accept Fate →
    </button>
  </div>
</div>

<script>
  const modal = document.getElementById("fate-modal");
  const continueBtn = document.getElementById("continue-fate-btn");

  continueBtn?.addEventListener("click", () => {
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    document.dispatchEvent(new Event("fate-continue"));
  });
</script>
