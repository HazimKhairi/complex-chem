---
import { cn } from "../../lib/utils";
import type { QuestionCard } from "../../lib/data/question-cards";

interface Props {
  card: QuestionCard;
  showAnswer?: boolean;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { card, showAnswer = false, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full h-auto min-h-56",
  md: "w-full h-auto min-h-64",
  lg: "w-full h-auto min-h-80",
};

const difficultyColors = {
  easy: "border-green-500",
  medium: "border-yellow-500",
  hard: "border-red-500",
};

const difficultyBadge = {
  easy: "bg-green-500",
  medium: "bg-yellow-500",
  hard: "bg-red-500",
};
---

<div
  class={cn(
    "question-card relative bg-white border-4 rounded-lg overflow-hidden transition-transform hover:scale-105",
    difficultyColors[card.difficulty],
    sizeClasses[size],
    className,
  )}
>
  <!-- Header -->
  <div class="flex items-center justify-between p-3 border-b-2 border-gray-200">
    <div class={cn("w-8 h-8 rounded-full flex items-center justify-center", difficultyBadge[card.difficulty])}>
      <span class="text-white font-bold text-xs">{card.difficulty[0].toUpperCase()}</span>
    </div>
    <span class="font-bold text-gray-700 text-sm">{card.points} pts</span>
  </div>

  <!-- Question Text -->
  <div class="p-4">
    <p class="text-sm font-medium text-gray-900 mb-4 leading-snug">{card.question}</p>

    <!-- Options -->
    <div class="space-y-2">
      {
        card.options.map((option, index) => (
          <div
            class={cn(
              "px-3 py-2 border rounded text-xs leading-tight",
              showAnswer && index === card.correctAnswer
                ? "border-green-600 bg-green-50 font-bold"
                : "border-gray-300 bg-gray-50",
            )}
          >
            <span class="font-bold mr-1">{String.fromCharCode(65 + index)}.</span>
            {option}
          </div>
        ))
      }
    </div>
  </div>
</div>
