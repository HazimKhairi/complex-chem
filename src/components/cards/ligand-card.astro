---
import { cn } from "../../lib/utils";
import type { Ligand } from "../../lib/data/ligands";

interface Props {
  ligand: Ligand;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { ligand, size = "md", class: className } = Astro.props;

const sizeClasses = {
  sm: "w-full h-auto min-h-56",
  md: "w-full h-auto min-h-64",
  lg: "w-full h-auto min-h-72",
};
---

<div
  class={cn(
    "ligand-card relative bg-white border-2 border-black overflow-hidden transition-transform hover:scale-105",
    sizeClasses[size],
    className,
  )}
>
  <!-- Header with colored background -->
  <div class="p-3 flex items-center justify-center" style={`background-color: ${ligand.color}`}>
    <h3 class="font-bold text-white text-2xl">{ligand.name}</h3>
  </div>

  <!-- Card Body -->
  <div class="p-3 pb-6 text-xs leading-relaxed space-y-1">
    <p><span class="font-semibold">Compound:</span> {ligand.fullName}</p>
    <p><span class="font-semibold">Classification:</span> {ligand.classification}</p>
    <p><span class="font-semibold">Coordination Type:</span> {ligand.coordinationType}</p>
    <p><span class="font-semibold">Donor Atom:</span> {ligand.donorAtom}</p>
    <p><span class="font-semibold">Nomenclature of Ligand:</span> {ligand.nomenclature}</p>
  </div>
</div>

<style>
  .ligand-card {
    border-radius: 8px 8px 50% 50% / 8px 8px 40% 40%;
  }
</style>
