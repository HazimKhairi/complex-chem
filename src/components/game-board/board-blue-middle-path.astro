    <td class="r7 b46 y20 g33"><span class="text-[8px] text-white">H₂O</span></td>
    <td class="b55 bg-sky-300"></td>
    <td
      class="r17 b4 y30 g43"
      style="background: #ef4444 url('/complexes/4.png') center/cover no-repeat !important;"
    ></td>
  </tr>
  <tr>
    <td class="r6 b45 y19 g32"><span class="text-[8px] text-white">bipy</span></td>
    <td class="b56 bg-sky-300"></td>
    <td class="r18 b5 y31 g44"><span class="text-[8px] text-white">acac</span></td>
  </tr>
</table>
