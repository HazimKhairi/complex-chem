---
import Layout from "../layouts/Layout.astro";
import GameSettingsMenu from "../components/game-settings-menu.astro";
---

<Layout>
  <GameSettingsMenu />
  <main class="min-h-screen p-4 flex flex-col items-center">
    <!-- Header -->
    <div class="w-full max-w-2xl mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-center text-ludon-blue">
        LEVEL 2 — Build Your Complex
      </h1>
      <p id="player-info" class="text-center text-gray-600 mt-1 text-sm"></p>
    </div>

    <!-- Step Indicator -->
    <div class="flex items-center justify-center gap-0 mb-6 w-full max-w-md">
      {[1, 2, 3, 4].map((n, i) => (
        <>
          <div
            class="step-dot flex items-center justify-center rounded-full text-white font-bold text-sm shrink-0"
            data-step={n}
          >
            {n}
          </div>
          {i < 3 && <div class="step-line flex-1" />}
        </>
      ))}
    </div>

    <!-- Step Content Container -->
    <div
      id="step-container"
      class="w-full max-w-2xl bg-white rounded-2xl shadow-md p-6 sm:p-8"
      style="min-height:400px;"
    >
      <p class="text-gray-400 text-center mt-20">Loading...</p>
    </div>

    <!-- 3D Canvas (hidden until Step 3) -->
    <div id="builder-container" class="w-full max-w-2xl mt-4 hidden">
      <div class="bg-white rounded-2xl shadow-md overflow-hidden">
        <canvas id="three-canvas" class="w-full" style="height:350px; touch-action:none;"></canvas>
        <div class="p-4 border-t border-gray-100">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Your Ligands — drag onto empty slots</p>
          <div id="ligand-inventory" class="flex flex-wrap gap-2 justify-center min-h-[60px]"></div>
        </div>
        <div class="p-4 border-t border-gray-100 flex justify-between items-center">
          <div class="text-sm text-gray-600">Slots filled: <strong id="slots-filled">0</strong> / <strong id="slots-total">0</strong></div>
          <div class="flex gap-2">
            <button id="btn-reset-3d" class="px-4 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 text-sm font-semibold">Reset</button>
            <button id="btn-submit-3d" class="px-4 py-2 rounded-lg bg-[#4187a0] text-white font-semibold text-sm hover:bg-[#357a91] disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed" disabled>Submit</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Score Bar -->
    <div class="w-full max-w-2xl mt-4 bg-white rounded-xl shadow-sm p-4 flex justify-around text-center">
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Level 1</p>
        <p id="l1-score" class="text-xl font-bold text-ludon-blue">0</p>
      </div>
      <div class="border-l border-gray-200"></div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Level 2</p>
        <p id="l2-score" class="text-xl font-bold text-ludon-green">0</p>
      </div>
      <div class="border-l border-gray-200"></div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wide">Grand Total</p>
        <p id="total-score" class="text-2xl font-bold text-ludon-red">0</p>
      </div>
    </div>
  </main>

  <script is:inline>
    if (!sessionStorage.getItem("game-state")) {
      window.location.href = "/pass-and-play";
    }
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.160.0/examples/js/controls/OrbitControls.js"></script>
  <script is:inline src="/scripts/audio-manager.js"></script>
  <script is:inline src="/scripts/joyride.js"></script>
  <script is:inline src="/scripts/level-2-3d-builder.js"></script>
  <script is:inline src="/scripts/level-2-game.js"></script>
  <script>
    // Play Level 2 intro chime on first user interaction (autoplay policy safe)
    (function () {
      let played = false;
      function playOnce() {
        if (played) return;
        played = true;
        if (window.AudioManager) window.AudioManager.play("level-2-start");
        document.removeEventListener("click", playOnce);
        document.removeEventListener("keydown", playOnce);
      }
      document.addEventListener("click", playOnce, { once: false });
      document.addEventListener("keydown", playOnce, { once: false });
    })();
  </script>
</Layout>

<style>
  .step-dot {
    width: 32px;
    height: 32px;
    background-color: #d1d5db;
    transition: background-color 0.3s, transform 0.3s;
  }
  .step-dot.active {
    background-color: #4187a0;
    transform: scale(1.15);
  }
  .step-dot.done {
    background-color: #10b981;
  }
  .step-line {
    height: 3px;
    background-color: #d1d5db;
    transition: background-color 0.3s;
  }
  .step-line.done {
    background-color: #10b981;
  }
</style>

<script is:inline>
  if (!localStorage.getItem('joyride-l2-done')) {
    setTimeout(function () {
      if (window.Joyride) window.Joyride.startLevel2();
    }, 500);
  }
</script>
